  <COMPONENT cid="caphyon.advinst.custcomp.AiErrorAliasComponent">
    <ROW AliasRowId="9" AliasRowOperation="2" Message="شیوانگار"/>
    <ROW AliasRowId="20" AliasRowOperation="2" Message="لطفا تا زمانیکه شیوانگار پیکربندی میشود منتظر بمانید"/>
    <ROW AliasRowId="32" AliasRowOperation="2" Message="نصب {شیوانگار} با موفقیت کامل شد."/>
    <ROW AliasRowId="33" AliasRowOperation="2" Message="نصب {شیوانگار} موفقیت&#8204;آمیز نبود."/>
    <ROW AliasRowId="4010" AliasRowOperation="2" Message="جدیدترین نسخه شیوانگار از قبل روی رایانه نصب شده است."/>
    <ROW AliasRowId="4152" AliasRowOperation="2" Message="آیا میخواهید تنظیمات و فایل های موقتی شیوانگار را حذف کنید؟"/>
    <ROW AliasRowId="4154" AliasRowOperation="2" Message="پیش نیاز [2] به درستی نصب نشده است. نصب شیوانگار ادامه یابد؟"/>
    <ROW AliasRowId="4156" AliasRowOperation="2" Message="موفق به دریافت صحیح فایل [2]نشد: خطای سی آر سی.. ادامه نصب شیوانگار؟"/>
    <ROW AliasRowId="5" AliasRowOperation="2" Message="نصب کننده با یک خطای غیرمنتظره در نصب این بسته مواجه شده است. این یک مشکل با این برنامه را نشان میدهد. کد خطا [1]هست. {{نشانوند هست: [2], [3], [4]}}"/>
    <ROW AliasRowId="18" AliasRowOperation="2" Message="نصب کننده بیش از این پاسخ نمیدهد."/>
    <ROW AliasRowId="19" AliasRowOperation="2" Message="نصب کننده نابهنگام متوقف شده است."/>
    <ROW AliasRowId="1719" AliasRowOperation="2" Message="نمیتوان به ویندوز نصب کننده دسترسی داشت.اگر در سیف مد ویندوز باشید این رخ میدهد، یا ویندوز نصب کننده بدرستی نصب نشده است.برای راهنمایی با پشتیبانی شخصی خود تماس بگیرید."/>
    <ROW AliasRowId="1932" AliasRowOperation="2" Message="سرویس ویندوز نصب کننده فایل ویندوزی حفاظت شده [2] را نمیتواند بروزرسانی کند. {{نسخه بسته: [3], نسخه حفاظت شده سیستم عامل: [4], SFP خطای: [5]}}"/>
    <ROW AliasRowId="1321" AliasRowOperation="2" Message="نصب کننده اجازه کافی برای تغییر این فایل ندارد: [2]."/>
    <ROW AliasRowId="1501" AliasRowOperation="2" Message="خطای دسترسی به داده ایمن شده. لطفا مطمئن شوید ویندوز نصب کننده بدرسی پیکربندی شده و دوباره سعی کنید."/>
    <ROW AliasRowId="1702" AliasRowOperation="2" Message="نصب کننده قبل از پیکربندی [2] برای ادامه،باید ریستارت شود.  روی &quot;بله&quot; برای ریستارت یا &quot;خیر&quot; برای ریستارت در زمانی دیگر کلیک کنید."/>
    <ROW AliasRowId="1720" AliasRowOperation="2" Message="این یک مشکل با بسته ویندوز نصب کننده هست. یک اسکریپت موردنیاز برای کامل شدن این نصب را نمیتوان اجرا کرد. با فروشنده بسته یا پشتیبانی شخصی تماس بگیرید..  {{اقدام دستی [2] خطای اسکریپت [3], [4]: [5] خط [6], ستون [7], [8] }}"/>
    <ROW AliasRowId="1721" AliasRowOperation="2" Message="این یک مشکل با بسته ویندوز نصب کننده هست. یک برنامه موردنیاز برای کامل شدن این نصب را نمیتوان اجرا کرد. با فروشنده بسته یا پشتیبانی شخصی تماس بگیرید.. {{اقدام: [2], مکان: [3], فرمان: [4] }}"/>
    <ROW AliasRowId="1722" AliasRowOperation="2" Message="این مشکل با بسته ویندوز نصب کننده هست. برنامه اجرا شده بعنوان بخشی از نصب همانطور که انتظار میرفت به پایان نرسیده است. با پشتیبانی شخصی یا فروشنده محصول تماس بگیرید.  {{اقدام [2], مکان: [3], فرمان: [4] }}"/>
    <ROW AliasRowId="1723" AliasRowOperation="2" Message="این یک مشکل با بسته ویندوز نصب کننده هست. یک دی ا&#1616;ل ا&#1616;ل موردنیاز برای کامل شدن این نصب را نمیتوان اجرا کرد. با فروشنده بسته یا پشتیبانی شخصی تماس بگیرید..  {{اقدام [2], ورودی: [3], کتابخانه: [4] }}"/>
    <ROW AliasRowId="1931" AliasRowOperation="2" Message="سرویس ویندوز نصب کننده نمیتواند فایل سیستمی [2] را بروزرسانی کند زیرا توسط ویندوز حفاظت میشود.  ممکن است شما نیاز به بروزرسانی سیستم برای صحیح کارکردن این برامه دارید. {{نسخه بسته: [3], نسخه حفاظت شده سیستم عامل: [4]}}"/>
    <ROW AliasRowId="1933" AliasRowOperation="2" Message="سرویس ویندوز نصب کننده نمیتواند یک یا تعداد بیشتری از فایل های حافظت شده را بروزرسانی کند. {{SFP خطای: [2].  لیست فایل های حافظت شده:\r\n[3]}}"/>
    <ROW AliasRowId="2939" AliasRowOperation="2" Message="ویندوز نصب کننده نمیتواند کاتالوگ فایل سیستمی حفاظت را از کش حذف کند. کاتالوگ: [2], خطا: [3]."/>
    <ROW AliasRowId="2219" AliasRowOperation="2" Message="پایگاه داده: [2]. فرمت پایگاه داده نصب کننده نامعتبر."/>
    <ROW AliasRowId="2246" AliasRowOperation="2" Message="پایگاه داده: [2]. فرمت تغيير شكل نصب کننده نامعتبر است"/>
    <ROW AliasRowId="2937" AliasRowOperation="2" Message="ویندوز نصب کننده نمیتواند کاتالوگ فایل سیستمی حفاظت را نصب کند. کاتالوگ: [2], خطا: [3]."/>
    <ROW AliasRowId="2938" AliasRowOperation="2" Message="ویندوز نصب کننده نمیتواند کاتالوگ فایل سیستمی حفاظت را از کش بازیابی کند. کاتالوگ: [2], خطا: [3]."/>
    <ROW AliasRowId="22" AliasRowOperation="2" Message="حذف نسخه قدیمی این برنامه..."/>
    <ROW AliasRowId="23" AliasRowOperation="2" Message="آماده سازی برای حذف نسخه قدیمی این برنامه..."/>
    <ROW AliasRowId="1301" AliasRowOperation="2" Message="فایل &apos;[2]&apos; را نمیتوان ایجاد کرد.  یک پوشه با این نام موجود است.  لطفا&#1611; نصب را لغو کرده و در پوشه&#8204;ای متفاوت تلاش کنید."/>
    <ROW AliasRowId="1303" AliasRowOperation="2" Message="نصب&#8204;کننده دسترسی کافی به این پوشه: [2] ندارد. ادامه نصب ممکن نیست. لطفا&#1611; به عنوان مدیر سیستم وارد شوید یا با مدیر سیستم در ارتباط باشید."/>
    <ROW AliasRowId="1304" AliasRowOperation="2" Message="خطای نوشتن در فایل: [2].  بررسی کنید اجازه نوشتن در این پوشه را دارید یا خیر."/>
    <ROW AliasRowId="1318" AliasRowOperation="2" Message="یک خطای شبکه حین ایجاد پوشه رخ داده است: [2]"/>
    <ROW AliasRowId="1312" AliasRowOperation="2" Message="پوشه &apos;[2]&apos; را نمیتوان ایجاد کرد.  یک فایل با این نام از قبل موجود است.  لطفا فایل را حذف یا تغییرنام دهید و روی &quot;دوباره&quot;، یا &quot;لغو&quot; برای خروج کلیک کنید."/>
    <ROW AliasRowId="1317" AliasRowOperation="2" Message="یک خطا حین سعی در ایجاد پوشه رخ داد: [2]"/>
    <ROW AliasRowId="2756" AliasRowOperation="2" Message="مشخصه &apos;[2]&apos; بعنوان مشخصه پوشه در یک یا تعداد بیشتری جدول بکاررفته است،اما هیچگونه مقداری اختصاص داده نشده است"/>
    <ROW AliasRowId="2327" AliasRowOperation="2" Message="این پوشه را نمیتوان حذف کرد: [3] گرفتن آخرین خطا: [2]."/>
    <ROW AliasRowId="2706" AliasRowOperation="2" Message="مسیرهای منبع ایجاد نشده است. مسیری برای ورودی در پوشه جدول [2] وجود ندارد."/>
    <ROW AliasRowId="2381" AliasRowOperation="2" Message="پوشه وجود ندارد: [2]."/>
    <ROW AliasRowId="2704" AliasRowOperation="2" Message="مشخصه ریشه پوشه تعریف نشده است: [2]"/>
    <ROW AliasRowId="2707" AliasRowOperation="2" Message="مسیرهای هدف ایجاد نشده است. مسیری برای ورودی [2] در جدول پوشه وجود ندارد."/>
    <ROW AliasRowId="2864" AliasRowOperation="2" Message="کنترل [3] در دیالوگ [2] یک رویداد جستجو دریافت کرده است. اما آنجا یک پوشه قابل پیکربندی برای انتخاب حاضر ندارد. علت محتمل: دکمه جستجو بطور صحیح باعث نشده است"/>
    <ROW AliasRowId="2727" AliasRowOperation="2" Message="ورودی پوشه &apos;[2]&apos; در جدول پوشه وجود ندارد."/>
    <ROW AliasRowId="2732" AliasRowOperation="2" Message="مدیریت پوشه مقداردهی نشده است"/>
    <ROW AliasRowId="2857" AliasRowOperation="2" Message="پوشه [2]در جدول انتخابی نگهداری شده است ولی یافت نشد."/>
    <ROW AliasRowId="2920" AliasRowOperation="2" Message="پوشه منبع برای فایل [2] مشخص نشده است."/>
    <ROW AliasRowId="2940" AliasRowOperation="2" Message="مدیریت پوشه برای تحلیل منبع تهیه نشده است."/>
    <ROW AliasRowId="4022" AliasRowOperation="2" Message="پوشه مجازی &quot;[2]&quot; در وب سایت &quot;[3]&quot; از قبل در این سرور موجود است.  آیا میخواهید این پوشه مجازی را رد کرده و نصب را ادامه دهید؟"/>
    <ROW AliasRowId="4027" AliasRowOperation="2" Message="پوشه مجازی &quot;[2]&quot; در وب سایت &quot;[3]&quot; از قبل در این سرور موجود است.  آیا میخواهید این پوشه مجازی را جایگزی و نصب را ادامه دهید؟ (این عملکرد غیرقابل بازگشت است.)"/>
    <ROW AliasRowId="1305" AliasRowOperation="2" Message="خطای خواندن از فایل [2]. {{ خطای سیستم [3].}} بررسی کنید فایل موجود است و اجازه دسترسی به آن را دارید یا خیر"/>
    <ROW AliasRowId="1306" AliasRowOperation="2" Message="برنامه دیگری دسترسی انحصاری به فایل &apos;[2]&apos; دارد. لطفا&#1611; سایر برنامه&#8204;ها را ببندید و دوباره تلاش کنید."/>
    <ROW AliasRowId="1307" AliasRowOperation="2" Message="فضای کافی بر روی دیسک برای نصب فایل &apos;[2]&apos; موجود نیست. لطفا&#1611; مقداری از فضای دیسک را خالی کرده و روی &apos;دوباره&apos; کلیک کنید، یا برای خروج روی &apos;لغو&apos; کلیک کنید."/>
    <ROW AliasRowId="1308" AliasRowOperation="2" Message="فایل منبع یافت نشد: [2].  بازبینی کنید فایل موجود است و شما دسترسی لازم به آن را دارید."/>
    <ROW AliasRowId="1309" AliasRowOperation="2" Message="خطای خواندن از فایل: [3]. {{ خطای سیستم [2].}}  بررسی کنید فایل موجود است و دسترسی لازم به آن را دارید."/>
    <ROW AliasRowId="1310" AliasRowOperation="2" Message="خطای نوشتن در فایل: [3]. {{ خطای سیستم [2].}} بررسی کنید شما دسترسی لازم به آن را دارید."/>
    <ROW AliasRowId="1311" AliasRowOperation="2" Message="فایل منبع یافت نشد{{(cabinet)}}: [2].  بررسی کنید فایل وجود دارد و به آن دسترسی دارید."/>
    <ROW AliasRowId="1313" AliasRowOperation="2" Message="درایو &apos;[2]&apos; اکنون غیرقابل دسترسی است. لطفا&#1611; درایو دیگری را انتخاب کنید."/>
    <ROW AliasRowId="1315" AliasRowOperation="2" Message="قادر به نوشتن در پوشه مشخص شده نیست: [2]."/>
    <ROW AliasRowId="1707" AliasRowOperation="2" Message="نصب با موفقیت به پایان رسید."/>
