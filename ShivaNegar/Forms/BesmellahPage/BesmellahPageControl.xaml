<UserControl
    x:Class="ShivaNegar.Forms.BesmellahPage.BesmellahPageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControl="clr-namespace:ShivaNegar.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <Border
            Grid.RowSpan="2"
            Background="{StaticResource PrimaryBackgroundColor}"
            CornerRadius="10" />

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                VerticalAlignment="Top"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Viewbox HorizontalAlignment="Left" StretchDirection="DownOnly">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnCloseApp"
                            Width="30"
                            Height="30"
                            Margin="5"
                            Foreground="White"
                            Style="{DynamicResource MaterialDesignIconButton}"
                            ToolTip="بستن پنجره">
                            <materialDesign:PackIcon Kind="WindowClose" />
                        </Button>

                        
                    </StackPanel>
                </Viewbox>

                <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                    <TextBlock
                        x:Name="lblWindowName"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Text="ساخت صفحه بسم الله"
                        TextAlignment="Center" />
                </Viewbox>

            </Grid>

            <Grid x:Name="gridMain" Grid.Row="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.RowSpan="2"
                    Background="{StaticResource LightBackgroundColor}"
                    CornerRadius="10" />

                <Grid>
                    <StackPanel Margin="10">
                        <Grid Margin="10,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <ComboBox
                                    x:Name="comboBesmellahFontType"
                                    Grid.Row="0"
                                    Margin="0,0,0,20"
                                    materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                    materialDesign:HintAssist.FloatingScale="1"
                                    materialDesign:HintAssist.Hint="قالب بسم الله"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}" />


                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="6*" />
                                    </Grid.ColumnDefinitions>

                                    <ListBox
                                        x:Name="lstBoxNameOfAllah"
                                        Grid.Column="0"
                                        Width="Auto"
                                        Height="400"
                                        HorizontalContentAlignment="Center"
                                        FontFamily="B e s m e l l a h 2"
                                        FontSize="75"
                                        VirtualizingPanel.ScrollUnit="Item"
                                        VirtualizingStackPanel.IsVirtualizing="True">
                                        <d:ListBoxItem>
                                            1
                                        </d:ListBoxItem>
                                        <d:ListBoxItem>
                                            2
                                        </d:ListBoxItem>
                                        <d:ListBoxItem>
                                            3
                                        </d:ListBoxItem>
                                    </ListBox>


                                    <Viewbox
                                        Grid.Column="1"
                                        Height="300"
                                        Margin="30"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            x:Name="lblNameOfAllah"
                                            VerticalAlignment="Center"
                                            d:Text="2"
                                            FontFamily="B e s m e l l a h 2"
                                            Text="{Binding SelectedItem, ElementName=lstBoxNameOfAllah}"
                                            TextAlignment="Center" />
                                    </Viewbox>
                                </Grid>

                            </Grid>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" VerticalAlignment="Bottom">
                    <Button
                        x:Name="btnConfirmChanges"
                        Height="45"
                        Margin="5"
                        VerticalAlignment="Top"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Content="ایجاد صفحه بسم الله"
                        Foreground="{StaticResource LightButtonTextColor}" />
                </Grid>

                <customControl:LoadingControl
                    x:Name="loadingControl"
                    IsEnabled="False"
                    Tag="لطفا منتظر بمانید" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
