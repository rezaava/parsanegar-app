<UserControl
    x:Class="ShivaNegar.Forms.DocumentSettings.DocumentSettingsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="370"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- استایل جدید برای هدرهای افسانه‌ای -->
            <Style x:Key="LegendHeaderStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="10,0,10,0"/>
                <Setter Property="Padding" Value="0,0,5,0"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryBackgroundColor}"/>
                <Setter Property="Background" Value="{StaticResource LightBackgroundColor}"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <Border
            Grid.RowSpan="2"
            Background="{StaticResource PrimaryBackgroundColor}"
            CornerRadius="10" />

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                VerticalAlignment="Top"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Viewbox HorizontalAlignment="Left" StretchDirection="DownOnly">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnCloseApp"
                            Width="30"
                            Height="30"
                            Margin="5"
                            Foreground="White"
                            Style="{DynamicResource MaterialDesignIconButton}"
                            ToolTip="بستن پنجره">
                            <materialDesign:PackIcon Kind="WindowClose" />
                        </Button>

                        
                    </StackPanel>
                </Viewbox>

                <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                    <TextBlock
                        x:Name="lblWindowName"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Text="تنظیمات سند"
                        TextAlignment="Center" />
                </Viewbox>
            </Grid>

            <Border
                Grid.Row="1"
                Background="{StaticResource LightBackgroundColor}"
                CornerRadius="10">
                <ScrollViewer Margin="5" VerticalScrollBarVisibility="Auto">
                    <Viewbox
                        Grid.Column="1"
                        Margin="5,0"
                        VerticalAlignment="Top"
                        StretchDirection="DownOnly">

                        <StackPanel Width="340">

                            <!-- بخش همرسانی (بدون کارت) -->
                            <StackPanel Margin="0,0,0,15">
                                <Grid Margin="0,10">
                                    <Border 
                                        Height="1" 
                                        Background="{StaticResource PrimaryBackgroundColor}" 
                                        VerticalAlignment="Center" Margin="48,0,0,0"/>
                                    <TextBlock 
                                        Text="همرسانی" 
                                        Style="{StaticResource LegendHeaderStyle}" Margin="0,-2,0,3" RenderTransformOrigin="-0.021,0.491"/>
                                </Grid>

                                <StackPanel Margin="15,15">
                                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                        <StackPanel.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="در هنگام ذخیره و بستن سند، به طور خودکار عملیات همرسانی اتفاق میفتد" />
                                            </StackPanel>
                                        </StackPanel.ToolTip>

                                        <ToggleButton
                                            x:Name="tbtnAutoSaveOnClose"
                                            Margin="0,0,15,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            FlowDirection="LeftToRight"
                                            UseLayoutRounding="False" />

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,2,0" Text="همرسانی خودکار در هنگام بستن سند" />
                                            <materialDesign:PackIcon
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource PrimaryBackgroundColor}"
                                                Kind="QuestionMarkBox"
                                                UseLayoutRounding="False" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- بخش فهرست مطالب (بدون کارت) -->
                            <StackPanel Margin="0,0,0,15">
                                <Grid Margin="0,10">
                                    <Border 
                                        Height="1" 
                                        Background="{StaticResource PrimaryBackgroundColor}" 
                                        VerticalAlignment="Center" HorizontalAlignment="Left" Width="263" Margin="77,0,0,0"/>
                                    <TextBlock 
                                        Text="فهرست مطالب" 
                                        Style="{StaticResource LegendHeaderStyle}" Margin="0,-2,0,3" Width="71"/>
                                </Grid>

                                <StackPanel Margin="15,15">
                                    <ComboBox
                                        Name="comboTableOfContentIndentionStyle"
                                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="سبک فهرست مطالب"
                                        Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                        <ComboBoxItem>بدون تورفتگی</ComboBoxItem>
                                        <ComboBoxItem>با تورفتگی</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- بخش تغییر فونت پیشفرض (بدون کارت) -->
                            <StackPanel>
                                <Grid Margin="0,10">
                                    <Border 
                                        Height="1" 
                                        Background="{StaticResource PrimaryBackgroundColor}" 
                                        VerticalAlignment="Center" Margin="101,0,0,0"/>
                                    <TextBlock 
                                        Text="تغییر فونت پیشفرض" 
                                        Style="{StaticResource LegendHeaderStyle}" Margin="-5,0,0,0"/>
                                </Grid>

                                <StackPanel Margin="15,15">
                                    <Button
                                        x:Name="btnChangeDefaultFontPersian"
                                        Height="45"
                                        Margin="0,0,0,15"
                                        Content="فونت فارسی"
                                        Foreground="{StaticResource LightButtonTextColor}" />

                                    <Button
                                        x:Name="btnChangeDefaultFontEnglish"
                                        Height="45"
                                        Margin="0,0,0,15"
                                        Content="فونت انگلیسی"
                                        Foreground="{StaticResource LightButtonTextColor}" />
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </Viewbox>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>