<UserControl
    x:Class="ShivaNegar.Forms.ChangeContents.ChangeContentsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControl="clr-namespace:ShivaNegar.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <Border
            Grid.RowSpan="2"
            Background="{StaticResource PrimaryBackgroundColor}"
            CornerRadius="10" />

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                VerticalAlignment="Top"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Viewbox HorizontalAlignment="Left" StretchDirection="DownOnly">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnCloseApp"
                            Width="30"
                            Height="30"
                            Margin="5"
                            Foreground="White"
                            Style="{DynamicResource MaterialDesignIconButton}"
                            ToolTip="بستن پنجره">
                            <materialDesign:PackIcon Kind="WindowClose" />
                        </Button>

                        
                    </StackPanel>
                </Viewbox>

                <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                    <TextBlock
                        x:Name="lblWindowName"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Text="تغییر اطلاعات سند (آزمایشی)"
                        TextAlignment="Center" />
                </Viewbox>

            </Grid>

            <Grid x:Name="gridMain" Grid.Row="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.RowSpan="2"
                    Background="{StaticResource LightBackgroundColor}"
                    CornerRadius="10" />
                <ScrollViewer
                    x:Name="scrollContent"
                    Grid.Row="0"
                    VerticalAlignment="Top"
                    VerticalScrollBarVisibility="Auto"
                    VirtualizingPanel.ScrollUnit="Pixel">
                    <Grid>
                        <StackPanel Margin="10">
                            <Expander
                                x:Name="expanderNameOfAllah"
                                materialDesign:ExpanderAssist.HeaderBackground="WhiteSmoke"
                                Background="{StaticResource LightBackgroundColor}"
                                Header="کلمه بسم الله">

                                <Expander.Content>
                                    <Grid Margin="20,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <ComboBox
                                                x:Name="comboBesmellahFontType"
                                                Grid.Row="0"
                                                Margin="0,0,0,20"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="قالب بسم الله"
                                                Style="{StaticResource MaterialDesignOutlinedComboBox}" />


                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="6*" />
                                                </Grid.ColumnDefinitions>

                                                <ListBox
                                                    x:Name="lstBoxNameOfAllah"
                                                    Grid.Column="0"
                                                    Width="Auto"
                                                    Height="300"
                                                    HorizontalContentAlignment="Center"
                                                    FontFamily="B e s m e l l a h 2"
                                                    FontSize="75"
                                                    VirtualizingPanel.ScrollUnit="Item"
                                                    VirtualizingStackPanel.IsVirtualizing="True">
                                                    <d:ListBoxItem>
                                                        1
                                                    </d:ListBoxItem>
                                                    <d:ListBoxItem>
                                                        2
                                                    </d:ListBoxItem>
                                                    <d:ListBoxItem>
                                                        3
                                                    </d:ListBoxItem>
                                                </ListBox>


                                                <Viewbox
                                                    Grid.Column="1"
                                                    Height="300"
                                                    Margin="30"
                                                    VerticalAlignment="Center">
                                                    <TextBlock
                                                        x:Name="lblNameOfAllah"
                                                        VerticalAlignment="Center"
                                                        d:Text="2"
                                                        FontFamily="B e s m e l l a h 2"
                                                        Text="{Binding SelectedItem, ElementName=lstBoxNameOfAllah}"
                                                        TextAlignment="Center" />
                                                </Viewbox>
                                            </Grid>

                                        </Grid>
                                    </Grid>

                                </Expander.Content>
                            </Expander>
                            <Expander
                                x:Name="expanderEducationDetails"
                                materialDesign:ExpanderAssist.HeaderBackground="WhiteSmoke"
                                Background="{StaticResource LightBackgroundColor}"
                                Header="مشخصات تحصیلی">
                                <Expander.Content>
                                    <StackPanel x:Name="stackEducationDetails" Margin="10">
                                        <Grid
                                            x:Name="gridUniversity"
                                            Margin="0,0,0,20"
                                            IsEnabled="False">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <ComboBox
                                                Name="comboUniversity"
                                                Grid.Column="0"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="دانشگاه"
                                                Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                Tag="Persian"
                                                Visibility="Visible" />
                                        </Grid>

                                        <Grid x:Name="gridDepartment" Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <ComboBox
                                                Name="comboDepartment"
                                                Grid.Column="0"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="دانشکده"
                                                Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                Tag="Persian"
                                                Visibility="Visible" />

                                            <TextBox
                                                Name="txtBoxCustomDepartmentEn"
                                                Grid.Column="1"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="دانشکده (انگلیسی)"
                                                AcceptsReturn="False"
                                                AcceptsTab="False"
                                                FlowDirection="RightToLeft"
                                                MaxLines="1"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="English"
                                                TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid x:Name="gridGroup" Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <ComboBox
                                                Name="comboGroup"
                                                Grid.Column="0"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="گروه/بخش"
                                                Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                Tag="Persian"
                                                Visibility="Visible" />

                                            <TextBox
                                                Name="txtBoxCustomGroupEn"
                                                Grid.Column="1"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="گروه/بخش (انگلیسی)"
                                                AcceptsReturn="False"
                                                AcceptsTab="False"
                                                FlowDirection="RightToLeft"
                                                MaxLines="1"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="English"
                                                TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid x:Name="gridFeildOfStudy" Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!--<ComboBox
						Name="comboFieldOfStudy"
						Grid.Column="0"
						Margin="5"
						materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
						materialDesign:HintAssist.FloatingScale="1"
						materialDesign:HintAssist.Hint="رشته تحصیلی"
						Style="{StaticResource MaterialDesignOutlinedComboBox}"
						Visibility="Visible" />-->

                                            <TextBox
                                                Name="txtBoxFieldOfStudy"
                                                Grid.Column="0"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="رشته تحصیلی"
                                                AcceptsReturn="False"
                                                AcceptsTab="False"
                                                MaxLines="1"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="Persian"
                                                TextWrapping="Wrap"
                                                Visibility="Visible" />

                                            <TextBox
                                                Name="txtBoxFieldOfStudyEn"
                                                Grid.Column="1"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="رشته تحصیلی (انگلیسی)"
                                                AcceptsReturn="False"
                                                AcceptsTab="False"
                                                FlowDirection="RightToLeft"
                                                MaxLines="1"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="English"
                                                TextWrapping="Wrap"
                                                Visibility="Visible" />
                                        </Grid>

                                        <Grid x:Name="gridAreaOfStudy" Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox
                                                Name="txtBoxAreaOfStudy"
                                                Grid.Column="0"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="گرایش تحصیلی (اختیاری)"
                                                AcceptsReturn="False"
                                                AcceptsTab="False"
                                                MaxLines="1"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="Persian"
                                                TextWrapping="Wrap"
                                                Visibility="Visible" />

                                            <TextBox
                                                Name="txtBoxAreaOfStudyEn"
                                                Grid.Column="1"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="گرایش تحصیلی (اختیاری) (انگلیسی)"
                                                AcceptsReturn="False"
                                                AcceptsTab="False"
                                                FlowDirection="RightToLeft"
                                                MaxLines="1"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="English"
                                                TextWrapping="Wrap"
                                                Visibility="Visible" />
                                        </Grid>

                                        <Grid x:Name="gridAcademicDegree">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <ComboBox
                                                Name="comboAcademicDegree"
                                                Grid.Column="0"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="مقطع تحصیلی"
                                                Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                Visibility="Visible" />
                                        </Grid>


                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                            <Expander
                                x:Name="expanderDocumentDetails"
                                materialDesign:ExpanderAssist.HeaderBackground="WhiteSmoke"
                                Background="{StaticResource LightBackgroundColor}"
                                Header="مشخصات سند">
                                <StackPanel x:Name="stackDocumentDetails" Margin="10">

                                    <TextBox
                                        Name="txtBoxNameOfCourseFa"
                                        Grid.Column="0"
                                        Margin="5,5,5,25"
                                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="درس"
                                        AcceptsReturn="False"
                                        AcceptsTab="False"
                                        FlowDirection="RightToLeft"
                                        MaxLines="1"
                                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                        Tag="Persian"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />

                                    <Grid x:Name="gridTitle" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            Name="txtBoxTitleFa"
                                            Grid.Column="0"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="عنوان"
                                            AcceptsReturn="False"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="1"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="Persian"
                                            TextWrapping="Wrap"
                                            IsEnabled="False"/>

                                        <TextBox
                                            Name="txtBoxTitleEn"
                                            Grid.Column="1"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="عنوان (انگلیسی)"
                                            AcceptsReturn="False"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="1"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="English"
                                            TextWrapping="Wrap"
                                            Visibility="Visible"
                                            IsEnabled="False" />

                                    </Grid>

                                    <Grid x:Name="gridAuthor" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            Name="txtBoxAuthorFa"
                                            Grid.Column="0"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="نام و نام خانوادگی نگارنده"
                                            AcceptsReturn="False"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="1"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="Persian"
                                            TextWrapping="Wrap"
                                            IsEnabled="False"/>

                                        <TextBox
                                            Name="txtBoxAuthorEn"
                                            Grid.Column="1"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="نام و نام خانوادگی نگارنده (انگلیسی)"
                                            AcceptsReturn="False"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="1"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="English"
                                            TextWrapping="Wrap"
                                            Visibility="Visible"
                                            IsEnabled="False"/>
                                    </Grid>

                                    <Grid x:Name="gridSupervisor" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            Name="txtBoxSupervisorFa"
                                            Grid.Column="0"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="استاد راهنما"
                                            AcceptsReturn="True"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="3"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="Persian"
                                            TextWrapping="Wrap"
                                            IsEnabled="False"/>

                                        <TextBox
                                            Name="txtBoxSupervisorEn"
                                            Grid.Column="1"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="استاد راهنما (انگلیسی)"
                                            AcceptsReturn="True"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="3"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="English"
                                            TextWrapping="Wrap"
                                            Visibility="Visible"
                                            IsEnabled="False"/>
                                    </Grid>

                                    <Grid x:Name="gridAdvisor" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            Name="txtBoxAdvisorFa"
                                            Grid.Column="0"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="استاد مشاور (اختیاری)"
                                            AcceptsReturn="True"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="3"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="Persian"
                                            TextWrapping="Wrap" />

                                        <TextBox
                                            Name="txtBoxAdvisorEn"
                                            Grid.Column="1"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="استاد مشاور (انگلیسی) (اختیاری)"
                                            AcceptsReturn="True"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="3"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="English"
                                            TextWrapping="Wrap"
                                            Visibility="Visible" />
                                    </Grid>

                                    <Grid x:Name="gridDefenseDate" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            Name="txtBoxDefenseDateFa"
                                            Grid.Column="0"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="تاریخ دفاع (اختیاری)"
                                            AcceptsReturn="False"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="1"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="Persian"
                                            TextWrapping="Wrap" />

                                        <TextBox
                                            Name="txtBoxDefenseDateEn"
                                            Grid.Column="1"
                                            Margin="5"
                                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                            materialDesign:HintAssist.FloatingScale="1"
                                            materialDesign:HintAssist.Hint="تاریخ دفاع (انگلیسی) (اختیاری)"
                                            AcceptsReturn="False"
                                            AcceptsTab="False"
                                            FlowDirection="RightToLeft"
                                            MaxLines="1"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Tag="English"
                                            TextWrapping="Wrap"
                                            Visibility="Visible" />
                                    </Grid>


                                </StackPanel>
                            </Expander>
                            <Expander
                                x:Name="expanderAbstractAndKeywords"
                                materialDesign:ExpanderAssist.HeaderBackground="WhiteSmoke"
                                Background="{StaticResource LightBackgroundColor}"
                                Header="چکیده و کلیدواژه">
                                <Expander.Content>
                                    <StackPanel x:Name="stackAbstractAndKeywords" Margin="10,10,10,0">
                                        <Grid x:Name="gridAbstract" Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox
                                                Name="txtBoxAbstractFa"
                                                Grid.Column="0"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="چکیده"
                                                AcceptsReturn="True"
                                                AcceptsTab="False"
                                                FlowDirection="RightToLeft"
                                                MaxLines="20"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="Persian"
                                                TextWrapping="Wrap" />

                                            <TextBox
                                                Name="txtBoxAbstractEn"
                                                Grid.Column="1"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="چکیده (انگلیسی)"
                                                AcceptsReturn="True"
                                                AcceptsTab="False"
                                                FlowDirection="RightToLeft"
                                                MaxLines="20"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="English"
                                                TextWrapping="Wrap"
                                                Visibility="Visible" />

                                        </Grid>

                                        <Grid x:Name="gridKeyword" Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox
                                                Name="txtBoxKeywordFa"
                                                Grid.Column="0"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="کلمات کلیدی"
                                                AcceptsReturn="False"
                                                AcceptsTab="False"
                                                FlowDirection="RightToLeft"
                                                MaxLines="1"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="Persian"
                                                TextWrapping="Wrap" />

                                            <TextBox
                                                Name="txtBoxKeywordEn"
                                                Grid.Column="1"
                                                Margin="5"
                                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                                materialDesign:HintAssist.FloatingScale="1"
                                                materialDesign:HintAssist.Hint="کلمات کلیدی (انگلیسی)"
                                                AcceptsReturn="False"
                                                AcceptsTab="False"
                                                FlowDirection="RightToLeft"
                                                MaxLines="1"
                                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                Tag="English"
                                                TextWrapping="Wrap"
                                                Visibility="Visible" />
                                        </Grid>

                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <Grid Grid.Row="1" VerticalAlignment="Bottom">
                    <Button
                        x:Name="btnConfirmChanges"
                        Height="45"
                        Margin="5"
                        VerticalAlignment="Top"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Content="اعمال تغییرات"
                        Foreground="{StaticResource LightButtonTextColor}" />
                </Grid>

                <customControl:LoadingControl
                    x:Name="loadingControl"
                    IsEnabled="False"
                    Tag="در حال برقراری ارتباط با سرور" />
            </Grid>

        </Grid>

    </Grid>
</UserControl>
