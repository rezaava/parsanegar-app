<UserControl
    x:Class="ShivaNegar.Forms.CitationSettings.CitationSettingsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="370"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Style for section headers with legend effect -->
            <Style x:Key="SectionHeaderStyle" TargetType="Grid">
                <Setter Property="Height" Value="30"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
                <Setter Property="Margin" Value="0,5,0,15"/>
            </Style>

            <Style x:Key="HeaderLineStyle" TargetType="Border">
                <Setter Property="Height" Value="1"/>
                <Setter Property="Background" Value="{StaticResource PrimaryBackgroundColor}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="15,0"/>
                <Setter Property="Padding" Value="5,0"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryBackgroundColor}"/>
                <Setter Property="Background" Value="{StaticResource LightBackgroundColor}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <Border
            Grid.RowSpan="2"
            Background="{StaticResource PrimaryBackgroundColor}"
            CornerRadius="10" />

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                VerticalAlignment="Top"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Viewbox HorizontalAlignment="Left" StretchDirection="DownOnly">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnCloseApp"
                            Width="30"
                            Height="30"
                            Margin="5"
                            Foreground="White"
                            Style="{DynamicResource MaterialDesignIconButton}"
                            ToolTip="بستن پنجره">
                            <materialDesign:PackIcon Kind="WindowClose" />
                        </Button>

                        
                    </StackPanel>
                </Viewbox>

                <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                    <TextBlock
                        x:Name="lblWindowName"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Text="تنظیمات فهرست و جداول"
                        TextAlignment="Center" />
                </Viewbox>
            </Grid>

            <Border
                Grid.Row="1"
                Background="{StaticResource LightBackgroundColor}"
                CornerRadius="10">
                <ScrollViewer Margin="5" VerticalScrollBarVisibility="Auto">
                    <Viewbox
                        Grid.Column="1"
                        Margin="5,0"
                        VerticalAlignment="Top"
                        StretchDirection="DownOnly">
                        <StackPanel Width="340">
                            <!-- منابع Section -->
                            <StackPanel Margin="0,5">
                                <!-- Header with legend effect -->
                                <Grid Style="{StaticResource SectionHeaderStyle}">
                                    <Border Style="{StaticResource HeaderLineStyle}" Margin="35,0,0,0"/>
                                    <TextBlock
                                        Text="منابع"
                                        Style="{StaticResource HeaderTextStyle}" RenderTransformOrigin="-0.363,0.692" Margin="0,0,308,0" HorizontalAlignment="Stretch"/>
                                </Grid>

                                <StackPanel Margin="15,10">
                                    <ComboBox
                                        Name="comboCitationDisplayStyle"
                                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="سبک نمایش منابع"
                                        Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                        <ComboBoxItem>APA</ComboBoxItem>
                                        <ComboBoxItem>IEEE</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Add more sections here following the same pattern if needed -->
                        </StackPanel>
                    </Viewbox>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>