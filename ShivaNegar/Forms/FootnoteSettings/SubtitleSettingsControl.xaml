<UserControl
    x:Class="ShivaNegar.Forms.FootnoteSettings.FootnoteSettingsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="370"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- استایل جدید برای هدرهای افسانه‌ای -->
            <Style x:Key="LegendHeaderStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="10,0,10,0"/>
                <Setter Property="Padding" Value="0,0,5,0"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryBackgroundColor}"/>
                <Setter Property="Background" Value="{StaticResource LightBackgroundColor}"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <Border
            Grid.RowSpan="2"
            Background="{StaticResource PrimaryBackgroundColor}"
            CornerRadius="10" />

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                VerticalAlignment="Top"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Viewbox HorizontalAlignment="Left" StretchDirection="DownOnly">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnCloseApp"
                            Width="30"
                            Height="30"
                            Margin="5"
                            Foreground="White"
                            Style="{DynamicResource MaterialDesignIconButton}"
                            ToolTip="بستن پنجره">
                            <materialDesign:PackIcon Kind="WindowClose" />
                        </Button>

                        
                    </StackPanel>
                </Viewbox>

                <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                    <TextBlock
                        x:Name="lblWindowName"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Text="تنظیمات پانویس"
                        TextAlignment="Center" />
                </Viewbox>
            </Grid>

            <Border
                Grid.Row="1"
                Background="{StaticResource LightBackgroundColor}"
                CornerRadius="10">
                <ScrollViewer Margin="5" VerticalScrollBarVisibility="Auto">
                    <Viewbox
                        Grid.Column="1"
                        Margin="5,0"
                        VerticalAlignment="Top"
                        StretchDirection="DownOnly">
                        <StackPanel Width="340">
                            <!-- بخش پانویس (بدون کارت) -->
                            <StackPanel>
                                <Grid Margin="0,10">
                                    <Border 
                                        Height="1" 
                                        Background="{StaticResource PrimaryBackgroundColor}" 
                                        VerticalAlignment="Center" Margin="37,0,0,0"/>
                                    <TextBlock 
                                        Text="پانویس" 
                                        Style="{StaticResource LegendHeaderStyle}" Margin="4,0,0,0" Width="36"/>
                                </Grid>

                                <StackPanel Margin="15,15">
                                    <ComboBox
                                        Name="comboFootnoteStyle"
                                        Margin="0,0,0,10"
                                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="نحوه نمایش پانویس"
                                        Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                        <ComboBoxItem>معمولی</ComboBoxItem>
                                        <ComboBoxItem>دو ستونه</ComboBoxItem>
                                    </ComboBox>
                                    <ComboBox
                                        Name="comboFootnoteSeparatorDefault"
                                        Margin="0,0,0,10"
                                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="وضعیت خط جدا کننده پانویس"
                                        Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                        <ComboBoxItem>پیشفرض</ComboBoxItem>
                                        <ComboBoxItem>راست</ComboBoxItem>
                                        <ComboBoxItem>چپ</ComboBoxItem>
                                        <ComboBoxItem>وسط</ComboBoxItem>
                                        <ComboBoxItem>ممتد</ComboBoxItem>
                                    </ComboBox>

                                    <ComboBox
                                        Name="comboFootnoteNumberStyle"
                                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="شیوه ارجاع به پانویس"
                                        Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                        <ComboBoxItem>پیشفرض</ComboBoxItem>
                                        <ComboBoxItem>همراه با خط تیره</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Viewbox>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>