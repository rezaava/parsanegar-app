<UserControl
    x:Class="ShivaNegar.Forms.AddRemovePages.AddRemovePagesControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControl="clr-namespace:ShivaNegar.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <Border
            Grid.RowSpan="2"
            Background="{StaticResource PrimaryBackgroundColor}"
            CornerRadius="10" />

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                VerticalAlignment="Top"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Viewbox HorizontalAlignment="Left" StretchDirection="DownOnly">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnCloseApp"
                            Width="30"
                            Height="30"
                            Margin="5"
                            Foreground="White"
                            Style="{DynamicResource MaterialDesignIconButton}"
                            ToolTip="بستن پنجره">
                            <materialDesign:PackIcon Kind="WindowClose" />
                        </Button>

                        
                    </StackPanel>
                </Viewbox>

                <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                    <TextBlock
                        x:Name="lblWindowName"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Text="حذف و اضافه صفحه (آزمایشی)"
                        TextAlignment="Center" />
                </Viewbox>
            </Grid>

            <Grid x:Name="gridMain" Grid.Row="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.RowSpan="2"
                    Background="{StaticResource LightBackgroundColor}"
                    CornerRadius="10" />

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card
                        Grid.Column="0"
                        Margin="5"
                        UniformCornerRadius="5">

                        <materialDesign:Card.Content>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid
                                    Grid.Row="0"
                                    Height="35"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource PrimaryBackgroundColor}">
                                    <TextBlock
                                        Margin="5,0,5,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource LightButtonTextColor}"
                                        Text="صفحات الزامی" />
                                </Grid>

                                <ScrollViewer
                                    Grid.Row="1"
                                    VerticalScrollBarVisibility="Auto"
                                    VirtualizingPanel.ScrollUnit="Pixel">

                                    <StackPanel
                                        x:Name="stackPanelEssentials"
                                        Grid.Row="1"
                                        Margin="10" />

                                </ScrollViewer>
                            </Grid>
                        </materialDesign:Card.Content>

                    </materialDesign:Card>

                    <materialDesign:Card
                        Grid.Column="1"
                        Margin="5"
                        UniformCornerRadius="5">
                        <materialDesign:Card.Content>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid
                                    Grid.Row="0"
                                    Height="35"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource PrimaryBackgroundColor}">
                                    <TextBlock
                                        Margin="5,0,5,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource LightButtonTextColor}"
                                        Text="صفحات اختیاری" />
                                </Grid>

                                <ScrollViewer
                                    Grid.Row="1"
                                    VerticalScrollBarVisibility="Auto"
                                    VirtualizingPanel.ScrollUnit="Pixel">
                                    <StackPanel
                                        x:Name="stackPanelOptionals"
                                        Grid.Row="1"
                                        Margin="10" />
                                </ScrollViewer>

                            </Grid>
                        </materialDesign:Card.Content>

                    </materialDesign:Card>

                    <materialDesign:Card
                        Grid.Column="2"
                        Margin="5"
                        UniformCornerRadius="5">

                        <materialDesign:Card.Content>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid
                                    Grid.Row="0"
                                    Height="35"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource PrimaryBackgroundColor}">
                                    <TextBlock
                                        Margin="5,0,5,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource LightButtonTextColor}"
                                        Text="فصل ها" />
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        x:Name="btnAddChapter"
                                        Grid.Column="0"
                                        Height="50"
                                        Padding="0"
                                        VerticalAlignment="Top"
                                        materialDesign:ButtonAssist.CornerRadius="0"
                                        materialDesign:ElevationAssist.Elevation="Dp0"
                                        Foreground="{StaticResource LightButtonTextColor}"
                                        ToolTip="اضافه کردن فصل">
                                        <Button.Content>
                                            <materialDesign:PackIcon
                                                Width="40"
                                                Height="40"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Foreground="{StaticResource LightButtonTextColor}"
                                                Kind="Plus" />
                                        </Button.Content>
                                    </Button>
                                    <Button
                                        x:Name="btnRemoveChapter"
                                        Grid.Column="1"
                                        Height="50"
                                        Padding="0"
                                        VerticalAlignment="Top"
                                        materialDesign:ButtonAssist.CornerRadius="0"
                                        materialDesign:ElevationAssist.Elevation="Dp0"
                                        Foreground="{StaticResource LightButtonTextColor}"
                                        ToolTip="حذف کردن فصل">
                                        <Button.Content>
                                            <materialDesign:PackIcon
                                                Width="40"
                                                Height="40"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Foreground="{StaticResource LightButtonTextColor}"
                                                Kind="Minus" />
                                        </Button.Content>
                                    </Button>
                                </Grid>

                                <ScrollViewer
                                    Grid.Row="2"
                                    VerticalScrollBarVisibility="Auto"
                                    VirtualizingPanel.ScrollUnit="Pixel">
                                    <StackPanel x:Name="stackPanelChapters" Margin="10" />
                                </ScrollViewer>
                            </Grid>
                        </materialDesign:Card.Content>

                    </materialDesign:Card>
                </Grid>

                <Grid Grid.Row="1" VerticalAlignment="Bottom">
                    <Button
                        x:Name="btnConfirmChanges"
                        Height="45"
                        Margin="5"
                        VerticalAlignment="Top"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Content="اعمال تغییرات"
                        Foreground="{StaticResource LightButtonTextColor}" />
                </Grid>

                <customControl:LoadingControl
                    x:Name="loadingCreating"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    IsEnabled="False"
                    Tag="لطفا منتظر بمانید" />

            </Grid>

        </Grid>


    </Grid>
</UserControl>
