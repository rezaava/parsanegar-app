<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.CreateDocument.CreateDocumentSlide4"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="0,0,10,10">
        <Grid x:Name="gridMain">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer
                Grid.Row="0"
                Margin="0,10,0,0"
                VerticalAlignment="Top"
                VerticalScrollBarVisibility="Auto"
                VirtualizingPanel.ScrollUnit="Pixel">

                <StackPanel
                    x:Name="stackContent"
                    Margin="10,0,10,0"
                    Orientation="Vertical">

                    <Grid x:Name="gridNameOfCourse">

                        <TextBox
                            Name="txtBoxNameOfCourseFa"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="درس"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="Persian"
                            TextWrapping="Wrap"
                            Visibility="Visible" />
                    </Grid>

                    <Grid x:Name="gridTitle">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Name="txtBoxTitleFa"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="عنوان"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="Persian"
                            TextWrapping="Wrap" />

                        <TextBox
                            Name="txtBoxTitleEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="عنوان (انگلیسی)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Visible" />

                    </Grid>

                    <Grid x:Name="gridAuthor">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Name="txtBoxAuthorFa"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="نام و نام خانوادگی نگارنده"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="Persian"
                            TextWrapping="Wrap" />

                        <TextBox
                            Name="txtBoxAuthorEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="نام و نام خانوادگی نگارنده (انگلیسی)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Visible" />
                    </Grid>

                    <Grid x:Name="gridSupervisor">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Name="txtBoxSupervisorFa"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="استاد(ان) راهنما / استاد درس"
                            AcceptsReturn="True"
                            AcceptsTab="False"
                            MaxLines="3"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="Persian"
                            TextWrapping="Wrap" />

                        <TextBox
                            Name="txtBoxSupervisorEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="استاد(ان) راهنما / استاد درس (انگلیسی)"
                            AcceptsReturn="True"
                            AcceptsTab="False"
                            MaxLines="3"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Visible" />
                    </Grid>

                    <Grid x:Name="gridAdvisor">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Name="txtBoxAdvisorFa"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="استاد(ان) مشاور (اختیاری)"
                            AcceptsReturn="True"
                            AcceptsTab="False"
                            MaxLines="3"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="Persian"
                            TextWrapping="Wrap" />

                        <TextBox
                            Name="txtBoxAdvisorEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="استاد(ان) مشاور (انگلیسی) (اختیاری)"
                            AcceptsReturn="True"
                            AcceptsTab="False"
                            MaxLines="3"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Visible" />
                    </Grid>

                    <Grid x:Name="gridDefenseDate">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Name="txtBoxDefenseDateFa"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="تاریخ دفاع (اختیاری)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="Persian"
                            TextWrapping="Wrap" />

                        <TextBox
                            Name="txtBoxDefenseDateEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="تاریخ دفاع (انگلیسی) (اختیاری)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Visible" />
                    </Grid>

                </StackPanel>

            </ScrollViewer>


            <Grid x:Name="gridTransitionButtons" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="btnBackward"
                    Grid.Column="0"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Command="{x:Static materialDesign:Transitioner.MovePreviousCommand}"
                    Content="قبلی"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="True" />

                <Button
                    x:Name="btnForward"
                    Grid.Column="1"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Command="{x:Static materialDesign:Transitioner.MoveNextCommand}"
                    Content="بعدی"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="False" />

            </Grid>
        </Grid>
    </Border>
</UserControl>
