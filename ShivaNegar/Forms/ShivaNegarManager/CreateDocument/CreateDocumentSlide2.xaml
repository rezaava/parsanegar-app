<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.CreateDocument.CreateDocumentSlide2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- استایل برای کارت پکیج -->
            <Style x:Key="PackageCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#FFF5F5F5"/>
                <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="15"/>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>


    <Border Background="White" CornerRadius="0,0,10,10">
        <Grid x:Name="gridMain">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer
                Grid.Row="0"
                Margin="0,10,0,0"
                VerticalAlignment="Top"
                VerticalScrollBarVisibility="Auto"
                VirtualizingPanel.ScrollUnit="Pixel">

                <StackPanel
                    x:Name="stackContent"
                    Margin="10,0,10,0"
                    Orientation="Vertical">

                    <TextBox
                        Name="txtDocumentName"
                        Grid.Column="0"
                        Margin="5"
                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                        materialDesign:HintAssist.FloatingScale="1"
                        materialDesign:HintAssist.Hint="نام سند (ترجیحاً با حروف انگلیسی)"
                        materialDesign:TextFieldAssist.CharacterCounterVisibility="Collapsed"
                        AcceptsReturn="False"
                        AcceptsTab="False"
                        FlowDirection="RightToLeft"
                        MaxLength="75"
                        MaxLines="1"
                        Tag="English"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Visibility="Visible" />

                    <ComboBox
                        x:Name="comboTemplateType"
                        Margin="5"
                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                        materialDesign:HintAssist.FloatingScale="1"
                        materialDesign:HintAssist.Hint="نوع قالب"
                        Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                    <ComboBox
                        x:Name="comboDocumentType"
                        Margin="5"
                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                        materialDesign:HintAssist.FloatingScale="1"
                        materialDesign:HintAssist.Hint="نوع سند"
                        Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                    <TextBlock x:Name="validationText" 
                               Text="وضعیت: منتظر انتخاب..."
                               Foreground="Gray"
                               FontSize="12"
                               Margin="10,5,0,0"/>

                    <Label
                        Margin="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="* فیلد های موجود به غیر از موارد &quot;(اختیاری)&quot; الزامی میباشد." />


                    <!-- کارت نمایش اطلاعات پکیج -->
                    <Border x:Name="packageCard" Style="{StaticResource PackageCardStyle}" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock
                                x:Name="txtPackageTitle"
                                Margin="10,0,0,0"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="#FF1976D2"
                                Text="برای استفاده از شیوانگار لطفا پکیج مربوطه را خریداری فرمایید."/>
                            

                            <StackPanel Margin="10,10,0,0" Orientation="Horizontal">
                                <TextBlock Text="مژده : " FontWeight="SemiBold" Foreground="#ff0000"/>
                                <TextBlock x:Name="txtOriginalPrice" Text="برای هر کاربر اولین تحقیق درسی، موضوع ویژه یا گزارش کارورزی رایگان می‌باشد." Margin="5,0,0,0"/>
                            </StackPanel>
                            <Button
                                x:Name="btnGoToWebsite"
                                Grid.Column="0"
                                Height="45"
                                Margin="0 10"
                                VerticalAlignment="Bottom"
                                materialDesign:ButtonAssist.CornerRadius="5"
                                materialDesign:ElevationAssist.Elevation="Dp2"
                                Content="رفتن به سایت و خرید پکیج"
                                Foreground="{StaticResource LightButtonTextColor}"
                                Click="BtnGoToWebsite_Click"
                                IsEnabled="True" />


                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="gridTransitionButtons" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="btnBackward"
                    Grid.Column="0"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Command="{x:Static materialDesign:Transitioner.MovePreviousCommand}"
                    Content="قبلی"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="True" />

                <Button
                    x:Name="btnForward"
                    Grid.Column="1"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Command="{x:Static materialDesign:Transitioner.MoveNextCommand}"
                    Content="بعدی"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="False" Visibility="Visible" />
                <Button
                    x:Name="btnStore"
                    Grid.Column="1"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Content="ساخت سند"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="True"
                    Visibility="Hidden"
                    Click="btnStore_Click"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>