<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.CreateDocument.CreateDocumentSlide3"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="0,0,10,10">
        <Grid x:Name="gridMain">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer
                x:Name="scrollContent"
                Grid.Row="0"
                Margin="0,10,0,0"
                VerticalAlignment="Top"
                VerticalScrollBarVisibility="Auto"
                VirtualizingPanel.ScrollUnit="Pixel">

                <StackPanel
                    x:Name="stackContent"
                    Margin="10,0,10,0"
                    Orientation="Vertical">

                    <Grid x:Name="gridUniversity">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Name="comboUniversity"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="دانشگاه"
                            Style="{StaticResource MaterialDesignOutlinedComboBox}"
                            Tag="Persian"
                            Visibility="Visible" />
                    </Grid>

                    <Grid x:Name="gridDepartment">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Name="comboDepartment"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="دانشکده / واحد"
                            Style="{StaticResource MaterialDesignOutlinedComboBox}"
                            Tag="Persian"
                            Visibility="Visible" />

                        <TextBox
                            Name="txtBoxCustomDepartmentEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="دانشکده (انگلیسی)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            FlowDirection="RightToLeft"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Collapsed" />
                    </Grid>

                    <Grid x:Name="gridGroup">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Name="comboGroup"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="گروه/بخش/مرکز آموزشی"
                            Style="{StaticResource MaterialDesignOutlinedComboBox}"
                            Tag="Persian"
                            Visibility="Visible" />

                        <TextBox
                            Name="txtBoxCustomGroupEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="گروه/بخش (انگلیسی)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            FlowDirection="RightToLeft"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Collapsed" />
                    </Grid>

                    <Grid x:Name="gridAcademicDegree">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Name="comboAcademicDegree"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="مقطع تحصیلی"
                            Style="{StaticResource MaterialDesignOutlinedComboBox}"
                            Tag="Persian"
                            Visibility="Visible" />
                    </Grid>

                    <Grid x:Name="gridFieldOfStudy">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--<ComboBox
						Name="comboFieldOfStudy"
						Grid.Column="0"
						Margin="5"
						materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
						materialDesign:HintAssist.FloatingScale="1"
						materialDesign:HintAssist.Hint="رشته تحصیلی"
						Style="{StaticResource MaterialDesignOutlinedComboBox}"
						Visibility="Visible" />-->

                        <TextBox
                            Name="txtBoxFieldOfStudy"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="رشته تحصیلی"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="Persian"
                            TextWrapping="Wrap"
                            Visibility="Visible" />

                        <TextBox
                            Name="txtBoxFieldOfStudyEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="رشته تحصیلی (انگلیسی)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            FlowDirection="RightToLeft"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Visible" />
                    </Grid>

                    <Grid x:Name="gridAreaOfStudy">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Name="txtBoxAreaOfStudy"
                            Grid.Column="0"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="گرایش تحصیلی (اختیاری)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="Persian"
                            TextWrapping="Wrap"
                            Visibility="Visible" />

                        <TextBox
                            Name="txtBoxAreaOfStudyEn"
                            Grid.Column="1"
                            Margin="5"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="گرایش تحصیلی (انگلیسی) (اختیاری)"
                            AcceptsReturn="False"
                            AcceptsTab="False"
                            FlowDirection="RightToLeft"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Tag="English"
                            TextWrapping="Wrap"
                            Visibility="Visible" />
                    </Grid>


                </StackPanel>

            </ScrollViewer>


            <Grid x:Name="gridTransitionButtons" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="btnBackward"
                    Grid.Column="0"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Command="{x:Static materialDesign:Transitioner.MovePreviousCommand}"
                    Content="قبلی"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="True" />

                <Button
                    x:Name="btnForward"
                    Grid.Column="1"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Command="{x:Static materialDesign:Transitioner.MoveNextCommand}"
                    Content="بعدی"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="False" />

            </Grid>
        </Grid>
    </Border>

</UserControl>
