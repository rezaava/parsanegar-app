<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.CreateDocument.CreateDocumentSlide1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="0,0,10,10">
        <Grid>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ComboBox
                        x:Name="comboBesmellahFontType"
                        Grid.Row="0"
                        Margin="15"
                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                        materialDesign:HintAssist.FloatingScale="1"
                        materialDesign:HintAssist.Hint="قالب بسم الله"
                        Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="6*" />
                        </Grid.ColumnDefinitions>

                        <ListBox
                            x:Name="lstBoxNameOfAllah"
                            Width="Auto"
                            HorizontalContentAlignment="Center"
                            FontFamily="B e s m e l l a h 2"
                            FontSize="75"
                            VirtualizingPanel.ScrollUnit="Item"
                            VirtualizingStackPanel.IsVirtualizing="True">
                            <d:ListBoxItem>
                                a
                            </d:ListBoxItem>
                        </ListBox>


                        <Viewbox
                            Grid.Column="1"
                            Margin="30"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Name="lblNameOfAllah"
                                d:Text="2"
                                FontFamily="B e s m e l l a h 2"
                                TextAlignment="Center" />
                        </Viewbox>
                    </Grid>
                </Grid>

                <Button
                    x:Name="btnGoCreateDocument"
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Command="{x:Static materialDesign:Transitioner.MoveNextCommand}"
                    Content="شروع"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="False" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
