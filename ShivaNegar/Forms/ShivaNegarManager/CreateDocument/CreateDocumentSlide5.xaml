<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.CreateDocument.CreateDocumentSlide5"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        Grid.Row="0"
        Grid.RowSpan="4"
        Background="White"
        CornerRadius="0,0,10,10">
        <Grid x:Name="gridMain">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:Card
                Grid.Row="0"
                Grid.Column="0"
                Margin="15"
                materialDesign:ElevationAssist.Elevation="Dp4"
                Background="#FFFAFAFA">
                <ScrollViewer
                    Margin="5"
                    VerticalScrollBarVisibility="Auto"
                    VirtualizingPanel.ScrollUnit="Pixel">

                    <StackPanel IsHitTestVisible="False">
                        <TextBlock
                            Padding="10"
                            FontSize="20"
                            Text="مشخصات سند" />

                        <DataGrid
                            x:Name="dataGridType"
                            Margin="0,10,0,10"
                            d:ItemsSource="{d:SampleData ItemCount=2}"
                            AutoGenerateColumns="False"
                            Foreground="Black"
                            HeadersVisibility="None"
                            IsReadOnly="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled">

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="نام">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding PersianValue}"
                                    Header="فارسی">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>

                                </DataGridTextColumn>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding EnglishValue}"
                                    Header="انگلیسی">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>

                                </DataGridTextColumn>
                            </DataGrid.Columns>

                        </DataGrid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Margin="17,0,0,10"
                                FontSize="13"
                                Text="آدرس سند" />
                            <TextBlock
                                x:Name="lblPath"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="17,0,0,10"
                                d:Text="C:\Users\Nazarian\Documents\ShivaNegarWorkspace\سند نمونه کامل.docx"
                                FlowDirection="LeftToRight"
                                FontSize="13"
                                TextAlignment="Right"
                                TextWrapping="Wrap" />

                        </Grid>


                        <TextBlock
                            Padding="10"
                            FontSize="20"
                            Text="مشخصات تحصیلی" />

                        <DataGrid
                            x:Name="dataGridUniversity"
                            Margin="0,0,0,10"
                            d:ItemsSource="{d:SampleData ItemCount=6}"
                            AutoGenerateColumns="False"
                            Foreground="Black"
                            HeadersVisibility="None"
                            IsReadOnly="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="نام">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>

                                </DataGridTextColumn>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding PersianValue}"
                                    Header="فارسی">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>

                                </DataGridTextColumn>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding EnglishValue}"
                                    Header="انگلیسی">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>

                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock
                            x:Name="lblDocumentInformation"
                            Padding="10"
                            d:Text="مشخصات پروژه"
                            FontSize="20" />

                        <DataGrid
                            x:Name="dataGridDocumentData"
                            Margin="0,0,0,10"
                            d:ItemsSource="{d:SampleData ItemCount=5}"
                            AutoGenerateColumns="False"
                            Foreground="Black"
                            HeadersVisibility="None"
                            IsReadOnly="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="نام">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>

                                </DataGridTextColumn>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding PersianValue}"
                                    Header="فارسی">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>

                                </DataGridTextColumn>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding EnglishValue}"
                                    Header="انگلیسی">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style>
                                            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>

            <CheckBox
                x:Name="chkBoxAgreement"
                Grid.Row="1"
                Margin="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom">
                <CheckBox.Content>
                    <TextBlock>
                        <!--<TextBlock Text="اطلاعات مربوطه به درستی وارد شده و اشکالی وجود ندارد" />-->
                        <TextBlock Text="با توجه به اینکه برخی اطلاعات وارد شده پس از ساخت سند غیر قابل تغییر خواهد بود، آنها را مجدد بررسی کرده و صحت آنها را تایید می‌کنم" TextWrapping="Wrap" />
                    </TextBlock>
                </CheckBox.Content>
            </CheckBox>

            <TextBlock
                Grid.Row="2"
                Margin="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom">
                <Hyperlink x:Name="lblHyperLinkSource">
                    <TextBlock Text="مشاهده شیوه نامه نگارش پایان نامه/رساله" ToolTip="لینک شیوه نامه" />
                    <TextBlock x:Name="lblHyperUniversity" d:Text="دانشگاه یزد" />
                </Hyperlink>

            </TextBlock>

            <Grid x:Name="gridTransitionButtons" Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="btnBackward"
                    Grid.Column="0"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Command="{x:Static materialDesign:Transitioner.MovePreviousCommand}"
                    Content="قبلی"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="True" />

                <!--  Command="{x:Static materialDesign:Transitioner.MoveNextCommand}"  -->
                <Button
                    x:Name="btnConfirmCreateDocument"
                    Grid.Column="1"
                    Height="45"
                    Margin="10"
                    VerticalAlignment="Bottom"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    materialDesign:ButtonProgressAssist.IsIndeterminate="False"
                    materialDesign:ButtonProgressAssist.IsIndicatorVisible="True"
                    materialDesign:ButtonProgressAssist.Value="-1"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Content="ساخت سند"
                    Foreground="{StaticResource LightButtonTextColor}"
                    IsEnabled="False" />

            </Grid>
        </Grid>
    </Border>
</UserControl>
