<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.DocumentManager.Models.FileViewModel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ShivaNegar.Forms.ShivaNegarManager.DocumentManager.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="200"
    d:DesignWidth="570"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>



    <Grid Name="panelMain">
        <Border
            BorderBrush="Black"
            BorderThickness="1"
            CornerRadius="5" />

        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>


            <Grid Grid.Row="0" Grid.Column="0">
                <Image
                    Width="32"
                    Height="32"
                    Margin="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Source="{Binding Image, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IconToImageSourceConverter}}" />
            </Grid>
            <Grid
                Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="5">

                <controls:HighlightableTextBlock
                    x:Name="lblTitle"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Selection="{Binding TitleSearched, UpdateSourceTrigger=PropertyChanged}"
                    Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />

            </Grid>

            <Grid Grid.Row="1" Grid.Column="0">
                <TextBlock
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Text="نوع سند"
                    TextAlignment="Left" />
            </Grid>
            <Grid
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="5">
                <!--  ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"  -->
                <!--  Foreground="{StaticResource LightTextColor}"  -->
                <TextBlock
                    x:Name="lblType"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{StaticResource LightTextColor}"
                    Text="{Binding Type, UpdateSourceTrigger=PropertyChanged, FallbackValue='نوع سند'}"
                    TextWrapping="Wrap" />
            </Grid>


            <Grid Grid.Row="2" Grid.Column="0">
                <TextBlock
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Text="نام سند"
                    TextAlignment="Left" />
            </Grid>

            <Grid
                Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="5">
                <!--  ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"  -->
                <!--  Foreground="{StaticResource LightTextColor}"  -->

                <TextBlock
                    x:Name="lblPath"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FlowDirection="LeftToRight"
                    FontSize="14"
                    Foreground="{StaticResource LightTextColor}"
                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, FallbackValue='نام سند'}"
                    TextAlignment="Right"
                    TextWrapping="Wrap" />

                <!--<TextBlock>
					<Hyperlink Click="Hyperlink_Click" TextDecorations="None">
						<TextBlock
							x:Name="lblPath"
							Margin="0,0,5,0"
							VerticalAlignment="Top"
							FlowDirection="LeftToRight"
							FontSize="12"
							Text="{Binding Path, UpdateSourceTrigger=PropertyChanged, FallbackValue='sample of path > C:\\Users'}"
							TextAlignment="Right"
							TextWrapping="Wrap"
							ToolTip="بازکردن آدرس سند" />
					</Hyperlink>
				</TextBlock>-->
            </Grid>

            <Grid
                Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="6">
                <Separator Height="2" Background="Black" />
            </Grid>

            <Grid Grid.Row="4" Grid.Column="0">
                <TextBlock
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Text="دانشگاه"
                    TextAlignment="Left" />
            </Grid>
            <Grid Grid.Row="4" Grid.Column="1">
                <TextBlock
                    x:Name="lblUniversity"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    Foreground="{StaticResource LightTextColor}"
                    Text="{Binding UniversityName, UpdateSourceTrigger=PropertyChanged, FallbackValue='دانشگاه مورد نظر'}"
                    TextWrapping="Wrap" />
            </Grid>

            <Grid Grid.Row="4" Grid.Column="2">
                <TextBlock
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Text="دانشکده"
                    TextAlignment="Left" />
            </Grid>
            <Grid Grid.Row="4" Grid.Column="3">
                <TextBlock
                    x:Name="lblDepartment"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    Foreground="{StaticResource LightTextColor}"
                    Text="{Binding DepartmentOfUniversity, UpdateSourceTrigger=PropertyChanged, FallbackValue='دانشکده مورد نظر'}"
                    TextWrapping="Wrap" />
            </Grid>

            <Grid Grid.Row="4" Grid.Column="4">
                <TextBlock
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Text="گروه/بخش"
                    TextAlignment="Left" />
            </Grid>
            <Grid Grid.Row="4" Grid.Column="5">
                <TextBlock
                    x:Name="lblGroup"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    Foreground="{StaticResource LightTextColor}"
                    Text="{Binding GroupOFUniversity, UpdateSourceTrigger=PropertyChanged, FallbackValue='گروه مورد نظر'}"
                    TextWrapping="Wrap" />
            </Grid>



            <Grid Grid.Row="5" Grid.Column="0">
                <TextBlock
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Text="نویسنده"
                    TextAlignment="Left" />
            </Grid>
            <Grid Grid.Row="5" Grid.Column="1">
                <TextBlock
                    x:Name="lblAuthor"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    Foreground="{StaticResource LightTextColor}"
                    Text="{Binding Author, UpdateSourceTrigger=PropertyChanged, FallbackValue='نویسنده مورد نظر'}"
                    TextWrapping="Wrap" />
            </Grid>

            <Grid Grid.Row="5" Grid.Column="2">
                <TextBlock
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Text="رشته"
                    TextAlignment="Left" />
            </Grid>
            <Grid Grid.Row="5" Grid.Column="3">
                <TextBlock
                    x:Name="lblFieldOfStudy"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    Foreground="{StaticResource LightTextColor}"
                    Text="{Binding FieldOfStudy, UpdateSourceTrigger=PropertyChanged, FallbackValue='رشته مورد نظر'}"
                    TextWrapping="Wrap" />
            </Grid>

            <Grid Grid.Row="5" Grid.Column="4">
                <TextBlock
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="{StaticResource LightTextColor}"
                    Text="استاد راهنما"
                    TextAlignment="Left" />
            </Grid>
            <Grid Grid.Row="5" Grid.Column="5">
                <TextBlock
                    x:Name="lblSupervisor"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top"
                    FontSize="12"
                    Foreground="{StaticResource LightTextColor}"
                    Text="{Binding Supervisor, UpdateSourceTrigger=PropertyChanged, FallbackValue='استاد راهنما مورد نظر'}"
                    TextWrapping="Wrap" />
            </Grid>

            <Grid
                Grid.Row="6"
                Grid.Column="0"
                Grid.ColumnSpan="6">

                <Expander Margin="5,5,5,5" Foreground="{StaticResource LightTextColor}">
                    <Expander.Style>
                        <Style TargetType="Expander" />
                    </Expander.Style>

                    <Expander.Header>
                        <TextBlock
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{StaticResource LightTextColor}"
                            Text="نمایش چکیده" />
                    </Expander.Header>
                    <Expander.Content>
                        <!--<TextBlock
							x:Name="lblAbstract"
							FontSize="12"
							Text="{Binding Abstract, UpdateSourceTrigger=PropertyChanged, FallbackValue='متن نمونه از چکیده'}"
							TextWrapping="Wrap" />-->
                        <TextBlock
                            x:Name="lblAbstract"
                            FontSize="12"
                            Text="{Binding Abstract, UpdateSourceTrigger=PropertyChanged, FallbackValue='متن نمونه از چکیده'}"
                            TextWrapping="Wrap" />

                    </Expander.Content>
                </Expander>
            </Grid>

        </Grid>

    </Grid>
</UserControl>
