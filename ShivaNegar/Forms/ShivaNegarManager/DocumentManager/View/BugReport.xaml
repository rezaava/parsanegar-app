<UserControl
	x:Class="ShivaNegar.Forms.ShivaNegarManager.DocumentManager.View.BugReport"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	d:DesignHeight="600"
	d:DesignWidth="570"
	FlowDirection="RightToLeft"
	FontFamily="Vazirmatn"
	mc:Ignorable="d">

	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</UserControl.Resources>

	<Border Background="{StaticResource LightBackgroundColor}" CornerRadius="10">
		<ScrollViewer
			Grid.Row="1"
			Margin="25"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Center"
			VerticalScrollBarVisibility="Auto"
			VirtualizingPanel.ScrollUnit="Pixel">

			<materialDesign:Card
				Margin="25"
				Width="400"
				Padding="10"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Center"
				materialDesign:ElevationAssist.Elevation="Dp2">

				<StackPanel>
					<Button
						x:Name="btnBack"
						Width="25"
						Height="25"
						Margin="0,0,0,20"
						HorizontalAlignment="Left"
						Style="{StaticResource MaterialDesignIconButton}"
						ToolTip="برگشت">
						<Button.Content>
							<materialDesign:PackIcon
								Width="25"
								Height="25"
								Foreground="#FF616161"
								Kind="ArrowForward" />
						</Button.Content>
					</Button>

					<Border Padding="5,0">

						<TextBox
							x:Name="txtReportText"
							MinHeight="100"
							Margin="0,10,0,15"
							materialDesign:HintAssist.Background="White"
							materialDesign:HintAssist.FloatingScale="1"
							materialDesign:HintAssist.Hint="توضیح خطا"
							materialDesign:TextFieldAssist.HasClearButton="True"
							AcceptsReturn="True"
							AcceptsTab="True"
							MaxLength="2000"
							Style="{StaticResource MaterialDesignOutlinedTextBox}"
							TextWrapping="Wrap" />
					</Border>

					<Border Padding="5,0">

						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>

							<TextBox
								x:Name="txtFilePath"
								Grid.Column="1"
								Margin="0,15,0,10"
								VerticalAlignment="Top"
								materialDesign:HintAssist.Background="White"
								materialDesign:HintAssist.FloatingScale="1"
								ToolTip="مستندات خطا شمال عکس، فیلم و..."
								materialDesign:HintAssist.Hint="مستندات خطا (اختیاری)"
								FlowDirection="RightToLeft"
								IsReadOnly="True"
								Style="{StaticResource MaterialDesignOutlinedTextBox}" />

							<Button
								x:Name="btnChooseFile"
								Grid.Column="0"
								Margin="0,0,10,0"
								HorizontalAlignment="Right"
								VerticalAlignment="Stretch"
								Content="..."
								Foreground="{StaticResource LightButtonTextColor}"
								ToolTip="انتخاب فایل (اختیاری)" />

						</Grid>
					</Border>

					<Border Padding="5">

						<Button
							x:Name="btnSendBugReport"
							Grid.Column="0"
							Height="50"
							Margin="0,30,0,15"
							VerticalAlignment="Bottom"
							materialDesign:ButtonAssist.CornerRadius="5"
							materialDesign:ElevationAssist.Elevation="Dp1"
							Content="ارسال گزارش"
							Foreground="{StaticResource LightButtonTextColor}" />
					</Border>


				</StackPanel>
			</materialDesign:Card>
		</ScrollViewer>
	</Border>
</UserControl>
