<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.DocumentManager.View.Documents"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControl="clr-namespace:ShivaNegar.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:ShivaNegar.Forms.ShivaNegarManager.DocumentManager.Models"
    d:DesignHeight="600"
    d:DesignWidth="622"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource LightBackgroundColor}" CornerRadius="10">

        <materialDesign:DialogHost
            x:Name="dialogMain"
            DialogContentUniformCornerRadius="15"
            DialogTheme="Inherit">

            <materialDesign:DialogHost.DialogContent>

                <Grid>
                    <Grid x:Name="gDialogUpdateOptional" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            Width="40"
                            Height="40"
                            Padding="15"
                            VerticalAlignment="Center"
                            Foreground="Orange"
                            Kind="Alert" />

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5"
                            VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" Text="سند جدیدی در سرور وجود دارد، آیا تمایل دارید از سند موجود در سرور استفاده کنید؟" />
                            <TextBlock FontWeight="Bold" Text="سند موجود حذف خواهد شد و سند جدید جایگزین آن خواهد شد" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnNewDocument"
                                Margin="0,8,8,0"
                                Content="بله"
                                IsDefault="True"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                            <Button
                                x:Name="btnUseCurrentDocument"
                                Margin="0,8,8,0"
                                Content="خیر"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </materialDesign:DialogHost.DialogContent>

            <Grid Name="panelMain">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>


                    <StackPanel Grid.Row="0" Margin="5">
                        <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>


                                <TextBox
                                    x:Name="txtSearchDocument"
                                    Margin="5"
                                    materialDesign:HintAssist.Background="White"
                                    materialDesign:HintAssist.FloatingScale="1"
                                    materialDesign:HintAssist.Hint="جستجو"
                                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                    materialDesign:TextFieldAssist.LeadingIcon="Search"
                                    Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                                <Button
                                    x:Name="btnTurnNetworkingDocument"
                                    Grid.Column="1"
                                    Margin="5"
                                    VerticalAlignment="Stretch"
                                    materialDesign:ButtonAssist.CornerRadius="5"
                                    Foreground="{StaticResource PrimaryBackgroundColor}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="اشتراک گذاری سند"
                                    Visibility="{Binding Path=SetAsArchive, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                                    <Button.Content>
                                        <materialDesign:PackIcon VerticalAlignment="Center" Kind="PersonNetwork" />
                                    </Button.Content>
                                </Button>

                                <Button
                                    x:Name="btnMoveToArchive"
                                    Grid.Column="2"
                                    Margin="5"
                                    VerticalAlignment="Stretch"
                                    materialDesign:ButtonAssist.CornerRadius="5"
                                    Foreground="{StaticResource PrimaryBackgroundColor}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="بایگانی سند"
                                    Visibility="{Binding Path=SetAsArchive, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                                    <Button.Content>
                                        <materialDesign:PackIcon VerticalAlignment="Center" Kind="ArchiveAdd" />
                                    </Button.Content>
                                </Button>

                                <Button
                                    x:Name="btnReturnFromArchive"
                                    Grid.Column="2"
                                    Margin="5"
                                    VerticalAlignment="Stretch"
                                    materialDesign:ButtonAssist.CornerRadius="5"
                                    Foreground="{StaticResource PrimaryBackgroundColor}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="انتقال به اسناد جاری"
                                    Visibility="{Binding Path=SetAsArchive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button.Content>
                                        <materialDesign:PackIcon VerticalAlignment="Center" Kind="ArchiveCancel" />
                                    </Button.Content>

                                </Button>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card
                            Height="50"
                            Margin="0,10,0,0"
                            materialDesign:ElevationAssist.Elevation="Dp1"
                            Background="{StaticResource PrimaryBackgroundColor}"
                            RenderTransformOrigin=".5,.5"
                            Visibility="{Binding Path=IsDocumentsOpened, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                x:Name="lblOpenedDocument"
                                Padding="20,0,20,0"
                                VerticalAlignment="Center"
                                FontSize="15"
                                Foreground="{StaticResource LightButtonTextColor}"
                                Text="{Binding Path=OpenedDocumentMessage, UpdateSourceTrigger=PropertyChanged}" />

                            <materialDesign:Card.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0" ScaleY="0" />
                                </TransformGroup>
                            </materialDesign:Card.RenderTransform>

                            <materialDesign:Card.Style>
                                <Style BasedOn="{StaticResource {x:Type materialDesign:Card}}" TargetType="materialDesign:Card">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=IsDocumentsOpened}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <RemoveStoryboard BeginStoryboardName="FadeOut" />
                                                <BeginStoryboard Name="FadeIn" Storyboard="{StaticResource FadeIn}" />
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Path=IsDocumentsOpened}" Value="False">
                                            <DataTrigger.EnterActions>
                                                <RemoveStoryboard BeginStoryboardName="FadeIn" />
                                                <BeginStoryboard Name="FadeOut" Storyboard="{StaticResource FadeOut}" />
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:Card.Style>

                        </materialDesign:Card>

                    </StackPanel>

                    <ListBox
                        x:Name="lstBoxFiles"
                        Grid.Row="1"
                        HorizontalContentAlignment="Stretch"
                        ItemsSource="{Binding FileModels, UpdateSourceTrigger=PropertyChanged}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectionChanged="lstBoxFiles_SelectionChanged"
                        VirtualizingPanel.ScrollUnit="Pixel"
                        VirtualizingStackPanel.IsVirtualizing="True">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <model:FileViewModel DataContext="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button
                        x:Name="btnOpenDocument"
                        Grid.Row="2"
                        Height="45"
                        Margin="5"
                        VerticalAlignment="Top"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Content="بازکردن سند"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Visibility="{Binding Path=SetAsArchive, Converter={StaticResource InvertBooleanToVisibilityConverter}}" />
                </Grid>


                <customControl:ShowMessageControl
                    x:Name="ShowMessageDocuments"
                    IsEnabled="{Binding Path=ShowMessage}"
                    Tag="{Binding Path=Message, UpdateSourceTrigger=PropertyChanged}" />

                <customControl:LoadingControl
                    x:Name="loadingDocuments"
                    IsEnabled="{Binding Path=ShowLoading}"
                    Tag="لطفا منتظر بمانید" />
            </Grid>

        </materialDesign:DialogHost>
    </Border>
</UserControl>
