<UserControl
	x:Class="ShivaNegar.Forms.ShivaNegarManager.DocumentManager.View.AboutUs"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:customControls="clr-namespace:ShivaNegar.CustomControls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	d:DesignHeight="500"
	d:DesignWidth="500"
	FlowDirection="RightToLeft"
	FontFamily="Vazirmatn"
	mc:Ignorable="d">

	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</UserControl.Resources>

	<Border Background="{StaticResource LightBackgroundColor}" CornerRadius="10">

		<Grid>
			<Viewbox
				Margin="25"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				StretchDirection="DownOnly">
				<materialDesign:Card
					Width="400"
					Padding="10"
					materialDesign:ElevationAssist.Elevation="Dp2">

					<StackPanel
						Margin="2"
						Background="White"
						Orientation="Vertical">
						<Button
							x:Name="btnBack"
							Width="25"
							Height="25"
							HorizontalAlignment="Left"
							Style="{StaticResource MaterialDesignIconButton}"
							ToolTip="برگشت">
							<Button.Content>
								<materialDesign:PackIcon
									Width="25"
									Height="25"
									Foreground="#FF616161"
									Kind="ArrowForward" />
							</Button.Content>
						</Button>


						<TextBlock
							x:Name="lblName"
							Padding="0,10"
							d:Text="شیوانگار"
							FontSize="25"
							FontWeight="Bold" />

						<TextBlock Padding="0,5">
							<TextBlock Text="نسخه:" />
							<TextBlock x:Name="lblVersion" d:Text="۱.۰.۰" />
						</TextBlock>

						<TextBlock Padding="0,5">
							<TextBlock Text="کپی رایت:" />
							<TextBlock
								x:Name="lblCopyright"
								d:Text="لورم ایپسوم" />
						</TextBlock>

						<TextBlock Padding="0,5">
							<TextBlock Text="شرکت:" />
							<TextBlock x:Name="lblCompany" d:Text="لورم ایپسوم" />
						</TextBlock>

						<TextBlock
							x:Name="lblDescription"
							Padding="0,5"
							d:Text="تمامی حقوق مادی و معنوی این نرم‌افزار(افزونه)، متعلق به شرکت لورم ایپسوم است؛ لذا هرگونه نسخه‌برداری از برنامه یا بخش هایی از آن پیگرد قانونی دارد."
							TextWrapping="Wrap" />

					</StackPanel>
				</materialDesign:Card>
			</Viewbox>
		</Grid>

	</Border>
</UserControl>
