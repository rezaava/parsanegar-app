<UserControl
	x:Class="ShivaNegar.Forms.ShivaNegarManager.DocumentManager.View.Profile"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	d:DesignHeight="500"
	d:DesignWidth="500"
	FlowDirection="RightToLeft"
	FontFamily="Vazirmatn"
	mc:Ignorable="d">

	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</UserControl.Resources>

	<Border Background="{StaticResource LightBackgroundColor}" CornerRadius="10">
		<Viewbox
			Margin="25"
			HorizontalAlignment="Center"
			VerticalAlignment="Center"
			StretchDirection="DownOnly">

			<materialDesign:Card
				Width="400"
				Padding="10"
				materialDesign:ElevationAssist.Elevation="Dp2">

				<StackPanel>

					<Border Padding="5,0">
						<TextBox
							x:Name="txtMobile"
							Margin="0,10,0,10"
							materialDesign:HintAssist.Background="White"
							materialDesign:HintAssist.FloatingScale="1"
							materialDesign:HintAssist.Hint="شماره موبایل"
							IsEnabled="False"
							MaxLength="11"
							Style="{StaticResource MaterialDesignOutlinedTextBox}" />
					</Border>
					<Border Padding="5,0">
						<TextBox
							x:Name="txtName"
							Margin="0,10,0,10"
							materialDesign:HintAssist.Background="White"
							materialDesign:HintAssist.FloatingScale="1"
							materialDesign:HintAssist.Hint="نام"
							Style="{StaticResource MaterialDesignOutlinedTextBox}" />
					</Border>
					<Border Padding="5,0">

						<TextBox
							x:Name="txtFamily"
							Margin="0,10,0,10"
							materialDesign:HintAssist.Background="White"
							materialDesign:HintAssist.FloatingScale="1"
							materialDesign:HintAssist.Hint="نام خانوادگی"
							Style="{StaticResource MaterialDesignOutlinedTextBox}" />
					</Border>

					<Border Padding="5">
						<Button
							x:Name="btnSaveChanges"
							Grid.Column="0"
							Height="45"
							Margin="0,30,5,0"
							VerticalAlignment="Bottom"
							materialDesign:ButtonAssist.CornerRadius="5"
							materialDesign:ElevationAssist.Elevation="Dp1"
							Content="ذخیره اطلاعات"
							Foreground="{StaticResource LightButtonTextColor}" />
					</Border>
				</StackPanel>
			</materialDesign:Card>
		</Viewbox>
	</Border>
</UserControl>
