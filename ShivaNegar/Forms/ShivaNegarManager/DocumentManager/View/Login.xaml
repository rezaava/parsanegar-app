<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.DocumentManager.View.Login"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:ShivaNegar.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="500"
    d:DesignWidth="500"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource LightBackgroundColor}" CornerRadius="10">

        <Grid>
            <Viewbox
                Margin="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                StretchDirection="DownOnly">
                <materialDesign:Card
                    Width="400"
                    Padding="10"
                    materialDesign:ElevationAssist.Elevation="Dp2">

                    <materialDesign:Transitioner
                        x:Name="transitionLoginRegister"
                        AutoApplyTransitionOrigins="True"
                        SelectedIndex="0">

                        <materialDesign:TransitionerSlide>
                            <materialDesign:TransitionerSlide.OpeningEffects>
                                <materialDesign:TransitionEffect Kind="FadeIn" />
                            </materialDesign:TransitionerSlide.OpeningEffects>
                            <materialDesign:TransitionerSlide.BackwardWipe>
                                <materialDesign:SlideWipe Direction="Right" />
                            </materialDesign:TransitionerSlide.BackwardWipe>
                            <materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:SlideWipe Direction="Left" />
                            </materialDesign:TransitionerSlide.ForwardWipe>

                            <Grid Background="White">
                                <StackPanel
                                    Margin="2"
                                    Background="White"
                                    Orientation="Vertical">

                                    <TextBlock Margin="0,0,0,20" FontSize="20">
                                        ورود | ثبت‌نام
                                    </TextBlock>
                                    <TextBlock Margin="0,0,0,5">
                                        سلام!
                                    </TextBlock>
                                    <TextBlock>
                                        لطفا شماره موبایل خود را وارد کنید
                                    </TextBlock>

                                    <TextBox
                                        x:Name="txtMobile"
                                        Margin="0,20,0,10"
                                        materialDesign:HintAssist.Background="White"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="شماره موبایل"
                                        MaxLength="11"
                                        Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                                    <Button
                                        x:Name="btnLogin"
                                        Height="45"
                                        Margin="0,30,0,0"
                                        VerticalAlignment="Bottom"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        materialDesign:ElevationAssist.Elevation="Dp1"
                                        Content="ورود"
                                        Foreground="{StaticResource LightButtonTextColor}" />

                                    <!--					<CheckBox
						x:Name="chkBoxAgreement"
						HorizontalAlignment="Left"
						VerticalAlignment="Bottom">
						<CheckBox.Content>
							<TextBlock>
								<Hyperlink x:Name="txtHyperLinkAgreement">
									<TextBlock Text="قوانین و مقررات" ToolTip="نمایش قوانین" />
								</Hyperlink>
								<TextBlock Text="مربوط به ساخت سند جدید را می‌پذیرم و به آن عمل می‌کنم" />
							</TextBlock>
						</CheckBox.Content>
					</CheckBox>							-->

                                    <TextBlock Margin="0,10,0,0">
                                        <TextBlock Text="ورود شما به معنای پذیرش" />
                                        <Hyperlink x:Name="lblHyperLinkAgreement">
                                            <TextBlock Text="شرایط و قوانین شیوانگار" ToolTip="نمایش شرایط" />
                                        </Hyperlink>
                                        <TextBlock Text="است" />
                                    </TextBlock>

                                    <!--							<TextBlock Margin="0,10,0,0">
								<TextBlock Text="ورود شما به معنای پذیرش" />
								<Hyperlink x:Name="txtHyperLinkAgreement">
									<TextBlock Text="شرایط شیوانگار" ToolTip="نمایش شرایط" />
								</Hyperlink>
								<TextBlock Text="و" />

								<Hyperlink x:Name="txtHyperLinkAgreement2">
									<TextBlock Text="قوانین حریم‌خصوصی" ToolTip="نمایش قوانین" />
								</Hyperlink>
								<TextBlock Text="است" />
							</TextBlock>							-->
                                </StackPanel>
                            </Grid>
                        </materialDesign:TransitionerSlide>

                        <materialDesign:TransitionerSlide>
                            <materialDesign:TransitionerSlide.OpeningEffects>
                                <materialDesign:TransitionEffect Kind="FadeIn" />
                            </materialDesign:TransitionerSlide.OpeningEffects>
                            <materialDesign:TransitionerSlide.BackwardWipe>
                                <materialDesign:SlideWipe Direction="Right" />
                            </materialDesign:TransitionerSlide.BackwardWipe>
                            <materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:SlideWipe Direction="Left" />
                            </materialDesign:TransitionerSlide.ForwardWipe>

                            <Grid Background="White">
                                <StackPanel Margin="2" Orientation="Vertical">

                                    <Button
                                        x:Name="btnBackToLogin"
                                        Width="25"
                                        Height="25"
                                        Margin="0,0,0,20"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="برگشت">
                                        <Button.Content>
                                            <materialDesign:PackIcon
                                                Width="25"
                                                Height="25"
                                                Foreground="#FF616161"
                                                Kind="ArrowForward" />
                                        </Button.Content>
                                    </Button>

                                    <TextBlock FontSize="20">
                                        رمز عبور را وارد کنید
                                    </TextBlock>

                                    <PasswordBox
                                        x:Name="txtPassword"
                                        Margin="0,20,0,10"
                                        materialDesign:HintAssist.Background="White"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="رمز عبور"
                                        Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" />
                                    <Button
                                        x:Name="btnChangePassword"
                                        HorizontalAlignment="Left"
                                        Content="فراموشی رمز عبور &gt;"
                                        Foreground="#FF616161">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <CheckBox
                                        x:Name="chkRememberUser"
                                        Margin="0,10,0,0"
                                        Content="مرا به خاطر بسپار"
                                        IsChecked="True" />


                                    <Button
                                        x:Name="btnLoginConfirm"
                                        Height="45"
                                        Margin="0,20,0,0"
                                        VerticalAlignment="Bottom"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        materialDesign:ElevationAssist.Elevation="Dp1"
                                        Content="تایید"
                                        Foreground="{StaticResource LightButtonTextColor}" />
                                </StackPanel>
                            </Grid>

                        </materialDesign:TransitionerSlide>

                        <materialDesign:TransitionerSlide>
                            <materialDesign:TransitionerSlide.OpeningEffects>
                                <materialDesign:TransitionEffect Kind="FadeIn" />
                            </materialDesign:TransitionerSlide.OpeningEffects>
                            <materialDesign:TransitionerSlide.BackwardWipe>
                                <materialDesign:SlideWipe Direction="Right" />
                            </materialDesign:TransitionerSlide.BackwardWipe>
                            <materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:SlideWipe Direction="Left" />
                            </materialDesign:TransitionerSlide.ForwardWipe>

                            <Grid Background="White">

                                <StackPanel Margin="2" Orientation="Vertical">

                                    <Button
                                        x:Name="btnBackToPassword"
                                        Width="25"
                                        Height="25"
                                        Margin="0,0,0,20"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="برگشت">
                                        <Button.Content>
                                            <materialDesign:PackIcon
                                                Width="25"
                                                Height="25"
                                                Foreground="#FF616161"
                                                Kind="ArrowForward" />
                                        </Button.Content>
                                    </Button>

                                    <TextBlock Margin="0,0,0,20" FontSize="20">
                                        تغییر رمز عبور
                                    </TextBlock>
                                    <TextBlock Margin="0,0,0,5">
                                        برای تغییر رمز عبور، شماره موبایل خود را وارد کنید
                                    </TextBlock>

                                    <TextBox
                                        x:Name="txtMobileForChangePassword"
                                        Margin="0,20,0,10"
                                        materialDesign:HintAssist.Background="White"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="شماره موبایل"
                                        MaxLength="11"
                                        Style="{StaticResource MaterialDesignOutlinedTextBox}" />


                                    <Button
                                        x:Name="btnRequestChangePassword"
                                        Height="45"
                                        Margin="0,30,0,0"
                                        VerticalAlignment="Bottom"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        materialDesign:ElevationAssist.Elevation="Dp1"
                                        Content="تایید"
                                        Foreground="{StaticResource LightButtonTextColor}" />
                                </StackPanel>
                            </Grid>
                        </materialDesign:TransitionerSlide>

                        <materialDesign:TransitionerSlide>
                            <materialDesign:TransitionerSlide.OpeningEffects>
                                <materialDesign:TransitionEffect Kind="FadeIn" />
                            </materialDesign:TransitionerSlide.OpeningEffects>
                            <materialDesign:TransitionerSlide.BackwardWipe>
                                <materialDesign:SlideWipe Direction="Right" />
                            </materialDesign:TransitionerSlide.BackwardWipe>
                            <materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:SlideWipe Direction="Left" />
                            </materialDesign:TransitionerSlide.ForwardWipe>

                            <Grid Background="White">

                                <StackPanel
                                    Margin="2"
                                    VerticalAlignment="Center"
                                    Orientation="Vertical">
                                    <TextBlock
                                        Margin="0,0,0,5"
                                        FontWeight="Bold"
                                        TextAlignment="Center">
                                        <TextBlock Text="رمز عبور جدید برای شماره " />
                                        <TextBlock x:Name="lblMobileInChangePassword" d:Text="09123456789" />
                                        <TextBlock Text=" ارسال گردید" />
                                    </TextBlock>

                                    <TextBlock
                                        Margin="0,0,0,5"
                                        FontWeight="Bold"
                                        TextAlignment="Center">
                                        برای ورود به حساب کاربری، رمز عبور جدید دریافتی را وارد نمایید
                                    </TextBlock>

                                    <Button
                                        x:Name="btnConfirmSendPassword"
                                        Height="45"
                                        Margin="0,30,0,0"
                                        VerticalAlignment="Bottom"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        materialDesign:ElevationAssist.Elevation="Dp1"
                                        Content="متوجه شدم"
                                        Foreground="{StaticResource LightButtonTextColor}" />
                                </StackPanel>
                            </Grid>
                        </materialDesign:TransitionerSlide>

                        <materialDesign:TransitionerSlide>
                            <materialDesign:TransitionerSlide.OpeningEffects>
                                <materialDesign:TransitionEffect Kind="FadeIn" />
                            </materialDesign:TransitionerSlide.OpeningEffects>
                            <materialDesign:TransitionerSlide.BackwardWipe>
                                <materialDesign:SlideWipe Direction="Right" />
                            </materialDesign:TransitionerSlide.BackwardWipe>
                            <materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:SlideWipe Direction="Left" />
                            </materialDesign:TransitionerSlide.ForwardWipe>

                            <Grid Background="White">

                                <StackPanel
                                    Margin="2"
                                    VerticalAlignment="Center"
                                    Orientation="Vertical">
                                    <TextBlock
                                        Margin="0,0,0,5"
                                        FontWeight="Bold"
                                        TextAlignment="Center">
                                        ثبت نام شما با موفقیت انجام شد
                                    </TextBlock>
                                    <!--<TextBlock
                                        Margin="0,0,0,5"
                                        FontWeight="Bold"
                                        TextAlignment="Center">
                                        <TextBlock Text="رمز عبور برای شماره " />
                                        <TextBlock x:Name="lblMobileInRegister" d:Text="09123456789" />
                                        <TextBlock Text=" ارسال گردید" />
                                    </TextBlock>-->
                                    <TextBlock
                                        Margin="0,0,0,5"
                                        FontWeight="Bold"
                                        TextAlignment="Center">
                                        برای ورود به حساب کاربری، رمز عبور دریافتی را وارد نمایید
                                    </TextBlock>

                                    <TextBlock
                                        Margin="0,0,0,5"
                                        FontWeight="Bold"
                                        TextAlignment="Center">
                                        موقتا رمز عبور شما 12345 میباشد
                                    </TextBlock>

                                    <Button
                                        x:Name="btnConfirmSendRegister"
                                        Height="45"
                                        Margin="0,30,0,0"
                                        VerticalAlignment="Bottom"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        materialDesign:ElevationAssist.Elevation="Dp1"
                                        Content="متوجه شدم"
                                        Foreground="{StaticResource LightButtonTextColor}" />
                                </StackPanel>
                            </Grid>
                        </materialDesign:TransitionerSlide>
                    </materialDesign:Transitioner>
                </materialDesign:Card>
            </Viewbox>

            <customControls:DialogBoxControl
                x:Name="dialogBox"
                IsEnabled="False"
                Tag="متن دیالوگ" />
        </Grid>

    </Border>
</UserControl>
