<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.DocumentManager.DocumentManagerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:ShivaNegar.Forms.ShivaNegarManager.DocumentManager.View"
    xmlns:vm="clr-namespace:ShivaNegar.Forms.ShivaNegarManager.DocumentManager.ViewModel"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type vm:DocumentsVM}">
                <view:Documents />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:SettingsVM}">
                <view:Settings />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:LoginVM}">
                <view:Login />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:AboutUsVM}">
                <view:AboutUs />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ProfileVM}">
                <view:Profile />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:BugReportVM}">
                <view:BugReport />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:MainVM}">
                <view:Main />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:NetworkingVM}">
                <view:Networking />
            </DataTemplate>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:NavigationVM x:Name="NavigationVm" />
    </UserControl.DataContext>

    <Border Background="White" CornerRadius="10">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>


            <Border
                x:Name="border"
                Grid.Column="0"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid x:Name="grid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />

                    </Grid.RowDefinitions>

                    <Viewbox
                        Grid.Row="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        StretchDirection="DownOnly">
                        <StackPanel Width="215" Orientation="Horizontal">

                            <Button
                                x:Name="btnCloseApp"
                                Width="30"
                                Height="30"
                                Foreground="White"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                ToolTip="بستن پنجره">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Kind="Close" />
                            </Button>

                            <Button
                                x:Name="btnWorkSpaceDirectory"
                                Width="30"
                                Height="30"
                                Foreground="White"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                ToolTip="بازکردن پوشه محیط کاری">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Kind="Folder" />
                            </Button>

                            <Button
                                x:Name="radioBtnSettings"
                                Width="30"
                                Height="30"
                                Command="{Binding SettingsCommand}"
                                Foreground="White"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                ToolTip="تنظیمات">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Kind="Settings" />
                            </Button>

                            <Button
                                x:Name="radioBtnProfile"
                                Width="30"
                                Height="30"
                                Command="{Binding ProfileCommand}"
                                Foreground="White"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                ToolTip="حساب کاربری">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Kind="Person" />
                            </Button>

                            <Button
                                x:Name="btnInfo"
                                Width="30"
                                Height="30"
                                Command="{Binding AboutUsCommand}"
                                Foreground="White"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                ToolTip="درباره نرم افزار(افزونه)">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Kind="Info" />
                            </Button>

                            <Button
                                x:Name="btnBugReport"
                                Width="30"
                                Height="30"
                                Command="{Binding BugReportCommand}"
                                Foreground="White"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                ToolTip="گزارش اشکال و خطا">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Kind="Bug" />
                            </Button>

                            <Button
                                x:Name="btnLogout"
                                Width="30"
                                Height="30"
                                Foreground="White"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                ToolTip="خروج از حساب کاربری">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Kind="Logout" />
                            </Button>

                        </StackPanel>
                    </Viewbox>
                    <Image
                        Grid.Row="1"
                        Margin="25"
                        Opacity="0.5"
                        Source="/ShivaNegar;component/Resources/Shivanegar_Overlay.png"
                        Stretch="Uniform" />


                    <StackPanel
                        Grid.Row="2"
                        Margin="10,0,10,10"
                        VerticalAlignment="Bottom">

                        <Button
                            x:Name="radioBtnAllDocuments"
                            Grid.Row="0"
                            Margin="0,5"
                            Padding="15,10,15,10"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            d:Height="45"
                            Background="#007ac1"
                            Command="{Binding AllDocumentsCommand}"
                            Foreground="White">
                            <Button.Style>
                                <Style BasedOn="{StaticResource MaterialDesignFlatDarkBgButton}" TargetType="Button">
                                    <Setter Property="Height" Value="Auto" />
                                </Style>
                            </Button.Style>

                            <Viewbox StretchDirection="DownOnly">

                                <StackPanel Width="165" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="30"
                                        Height="30"
                                        VerticalAlignment="Center"
                                        Kind="FileDocumentMultiple" />

                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Text="اسناد جاری" />
                                </StackPanel>
                            </Viewbox>
                        </Button>

                        <Button
                            x:Name="radioBtnNetworking"
                            Grid.Row="2"
                            Margin="0,5"
                            Padding="15,10,15,10"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            d:Height="45"
                            Background="#007ac1"
                            Command="{Binding NetworkingCommand}"
                            Foreground="White">
                            <Button.Style>
                                <Style BasedOn="{StaticResource MaterialDesignFlatDarkBgButton}" TargetType="Button">
                                    <Setter Property="Height" Value="Auto" />
                                </Style>
                            </Button.Style>

                            <Viewbox StretchDirection="DownOnly">
                                <materialDesign:Badged
                                    x:Name="badgeNetworking"
                                    BadgeColorZoneMode="PrimaryMid"
                                    BadgeForeground="{StaticResource LightButtonTextColor}"
                                    BadgePlacementMode="Right">

                                    <StackPanel Width="150" Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="30"
                                            Height="30"
                                            VerticalAlignment="Center"
                                            Kind="Notifications" />

                                        <TextBlock
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="18"
                                            Text="درخواست ها" />

                                    </StackPanel>
                                </materialDesign:Badged>
                            </Viewbox>
                        </Button>

                        <Button
                            x:Name="radioBtnCreateDocument"
                            Grid.Row="2"
                            Margin="0,5"
                            Padding="15,10,15,10"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            d:Height="45"
                            Background="#007ac1"
                            Foreground="White">
                            <Button.Style>
                                <Style BasedOn="{StaticResource MaterialDesignFlatDarkBgButton}" TargetType="Button">
                                    <Setter Property="Height" Value="Auto" />
                                </Style>
                            </Button.Style>

                            <Viewbox StretchDirection="DownOnly">
                                <StackPanel Width="165" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="30"
                                        Height="30"
                                        VerticalAlignment="Center"
                                        Kind="Add" />

                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Text="ساخت سند جدید" />
                                </StackPanel>
                            </Viewbox>
                        </Button>

                        <Button
                            x:Name="radioBtnArchives"
                            Grid.Row="1"
                            Margin="0,5"
                            Padding="15,10,15,10"
                            HorizontalContentAlignment="Left"
                            d:Height="45"
                            Background="#007ac1"
                            Command="{Binding ArchiveDocumentsCommand}"
                            Foreground="White"
                            Visibility="Visible">
                            <Button.Style>
                                <Style BasedOn="{StaticResource MaterialDesignFlatDarkBgButton}" TargetType="Button">
                                    <Setter Property="Height" Value="Auto" />
                                </Style>
                            </Button.Style>

                            <Viewbox StretchDirection="DownOnly">

                                <StackPanel Width="165" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="30"
                                        Height="30"
                                        VerticalAlignment="Center"
                                        Kind="Archive" />

                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Text="اسناد بایگانی" />
                                </StackPanel>
                            </Viewbox>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>
            <!--  // Pages //  -->
            <ContentControl
                x:Name="Pages"
                Grid.Column="1"
                Content="{Binding CurrentView}" />
        </Grid>
    </Border>

</UserControl>
