<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.ShivaNegarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:createDocument="clr-namespace:ShivaNegar.Forms.ShivaNegarManager.CreateDocument"
    xmlns:customControl="clr-namespace:ShivaNegar.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:documentManager="clr-namespace:ShivaNegar.Forms.ShivaNegarManager.DocumentManager"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:networkingManager="clr-namespace:ShivaNegar.Forms.ShivaNegarManager.NetworkingManager"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <!--  // Window Border //  -->
        <Border Background="White" CornerRadius="10" />


        <materialDesign:DialogHost
            x:Name="dialogMain"
            DialogContentUniformCornerRadius="15"
            DialogTheme="Inherit">

            <materialDesign:DialogHost.DialogContent>

                <Grid>
                    <Grid x:Name="gDialogServerError" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            Width="40"
                            Height="40"
                            Padding="15"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource ExitBackgroundButton}"
                            Kind="Error" />

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5"
                            VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" Text="در برقراری ارتباط با سرور مشکلی وجود دارد" />
                            <TextBlock FontWeight="Bold" Text="لطفا اتصال اینترنت خود را بررسی کنید." />
                        </StackPanel>


                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnServerTryAgainDialog"
                                Margin="0,8,8,0"
                                Content="تلاش مجدد"
                                IsDefault="True"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                            <Button
                                x:Name="btnServerCancelDialog"
                                Margin="0,8,8,0"
                                Content="لغو"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        </StackPanel>
                    </Grid>

                    <Grid
                        x:Name="gDialogUpdateOptional"
                        Margin="20"
                        Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            Width="40"
                            Height="40"
                            Padding="15"
                            VerticalAlignment="Center"
                            Foreground="Orange"
                            Kind="Alert" />

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5"
                            VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" Text="نسخه جدید از افزونه ارائه شده است و نصب آن اختیاری میباشد" />
                            <TextBlock FontWeight="Bold" Text="آیا تمایل به نصب نسخه جدید دارید؟" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnUpdateOptional"
                                Margin="0,8,8,0"
                                Content="بروزرسانی"
                                IsDefault="True"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                            <Button
                                x:Name="btnUpdateOptionalCancel"
                                Margin="0,8,8,0"
                                Content="بعداً"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        </StackPanel>
                    </Grid>

                    <Grid
                        x:Name="gDialogUpdateMandatory"
                        Margin="20"
                        Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            Width="40"
                            Height="40"
                            Padding="15"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource ExitBackgroundButton}"
                            Kind="AlertOctagon" />

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5"
                            VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" Text="نسخه جدیدی از افزونه منتشر شده و لازم است که برای ادامه کار نسخه جدید را نصب نمایید" />
                            <TextBlock FontWeight="Bold" Text="برای اینکار گزینه بروزرسانی را کلیک کرده تا وارد صفحه دانلود شوید" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnUpdateMandatory"
                                Margin="0,8,8,0"
                                Content="بروزرسانی"
                                IsDefault="True"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        </StackPanel>
                    </Grid>

                </Grid>
            </materialDesign:DialogHost.DialogContent>

            <Grid>

                <materialDesign:Transitioner
                    x:Name="transitionMain"
                    AutoApplyTransitionOrigins="True"
                    SelectedIndex="0">

                    <materialDesign:TransitionerSlide>
                        <materialDesign:TransitionerSlide.OpeningEffects>
                            <materialDesign:TransitionEffect Kind="FadeIn" />
                        </materialDesign:TransitionerSlide.OpeningEffects>

                        <materialDesign:TransitionerSlide.ForwardWipe>
                            <materialDesign:CircleWipe />
                        </materialDesign:TransitionerSlide.ForwardWipe>

                        <documentManager:DocumentManagerControl x:Name="documentManager" />

                    </materialDesign:TransitionerSlide>


                    <materialDesign:TransitionerSlide>
                        <materialDesign:TransitionerSlide.OpeningEffects>
                            <materialDesign:TransitionEffect Kind="FadeIn" />
                        </materialDesign:TransitionerSlide.OpeningEffects>

                        <materialDesign:TransitionerSlide.BackwardWipe>
                            <materialDesign:CircleWipe />
                        </materialDesign:TransitionerSlide.BackwardWipe>

                        <createDocument:CreateDocumentControl x:Name="createDocument" />

                    </materialDesign:TransitionerSlide>


                    <materialDesign:TransitionerSlide>
                        <materialDesign:TransitionerSlide.OpeningEffects>
                            <materialDesign:TransitionEffect Kind="FadeIn" />
                        </materialDesign:TransitionerSlide.OpeningEffects>

                        <materialDesign:TransitionerSlide.BackwardWipe>
                            <materialDesign:CircleWipe />
                        </materialDesign:TransitionerSlide.BackwardWipe>

                        <networkingManager:NetworkingManagerControl x:Name="networkingManagerControl" />

                    </materialDesign:TransitionerSlide>


                </materialDesign:Transitioner>

                <customControl:LoadingControl
                    x:Name="loadCtrlCheckingUpdated"
                    IsEnabled="True"
                    Tag="لطفا منتظر بمانید" />


            </Grid>

        </materialDesign:DialogHost>
    </Grid>

</UserControl>
