<UserControl
    x:Class="ShivaNegar.Forms.ShivaNegarManager.NetworkingManager.NetworkingManagerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="700"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource LightBackgroundColor}" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid
                x:Name="gridHeader"
                Grid.Row="0"
                materialDesign:ElevationAssist.Elevation="Dp12"
                Background="{StaticResource PrimaryBackgroundColor}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">

                    <Button
                        x:Name="btnExitCreateDocument"
                        Width="30"
                        Height="30"
                        Margin="5"
                        Foreground="White"
                        Style="{DynamicResource MaterialDesignIconButton}"
                        ToolTip="بستن پنجره">
                        <materialDesign:PackIcon Kind="WindowClose" />
                    </Button>

                    <Button
                        x:Name="btnMaximize"
                        Width="30"
                        Height="30"
                        Margin="0,5,5,5"
                        Foreground="White"
                        Style="{DynamicResource MaterialDesignIconButton}"
                        ToolTip="بزرگنمایی پنجره">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            Kind="WindowMaximize" />
                    </Button>

                    <Button
                        x:Name="btnMinimize"
                        Width="30"
                        Height="30"
                        Margin="0,5,5,5"
                        Foreground="White"
                        Style="{DynamicResource MaterialDesignIconButton}"
                        ToolTip="کوچکنمایی پنجره">
                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            Kind="WindowMinimize" />
                    </Button>
                </StackPanel>

                <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                    <TextBlock
                        x:Name="lblWindowName"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Text="اشتراک گذاری سند"
                        TextAlignment="Center" />
                </Viewbox>

                <StackPanel Grid.Column="2" Orientation="Horizontal">

                    <TextBlock
                        x:Name="lblVersion"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        d:Text="نسخه: ۱.۰.۳۰"
                        FontWeight="Bold"
                        Foreground="#BBFFFFFF"
                        TextAlignment="Center" />

                    <ToggleButton
                        Name="toggleButtonAlwaysOnTop"
                        Margin="10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FlowDirection="LeftToRight"
                        Style="{StaticResource MaterialDesignSwitchToggleButton}"
                        ToolTip="پنجره Always on Top تنظیم"
                        UseLayoutRounding="False">

                        <materialDesign:PackIcon Kind="Pin" RenderTransformOrigin=".5,.5">
                            <materialDesign:PackIcon.RenderTransform>
                                <RotateTransform Angle="45" />
                            </materialDesign:PackIcon.RenderTransform>
                        </materialDesign:PackIcon>

                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Foreground="{StaticResource LightBackgroundColor}" Kind="Pin" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>

                </StackPanel>
            </Grid>


            <materialDesign:Card Grid.Row="1" Margin="15">
                <ScrollViewer
                    CanContentScroll="True"
                    ScrollViewer.IsDeferredScrollingEnabled="True"
                    VerticalScrollBarVisibility="Auto"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Standard">
                    <StackPanel Margin="10">
                        <Grid x:Name="groupRequest" Margin="10,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="txtMobile"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Margin="5,0"
                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                materialDesign:HintAssist.FloatingScale="1"
                                materialDesign:HintAssist.Hint="شماره موبایل"
                                MaxLength="11"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                            <ComboBox
                                x:Name="comboRoleType"
                                Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Margin="5,0"
                                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                materialDesign:HintAssist.FloatingScale="1"
                                materialDesign:HintAssist.Hint="انتخاب نقش"
                                Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                            <Button
                                x:Name="btnSendNetworkingRequest"
                                Grid.Column="4"
                                Height="40"
                                Margin="5,0"
                                VerticalAlignment="Center"
                                materialDesign:ButtonAssist.CornerRadius="5"
                                materialDesign:ElevationAssist.Elevation="Dp2"
                                Content="ثبت درخواست"
                                Foreground="{StaticResource LightButtonTextColor}"
                                IsEnabled="True" />
                        </Grid>

                        <StackPanel Margin="10,5" Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="20"
                                Text="لیست کاربران مشترک" />

                            <Button
                                x:Name="btnRefreshList"
                                Margin="5,0,0,0"
                                materialDesign:ButtonAssist.CornerRadius="5"
                                Foreground="{StaticResource PrimaryBackgroundColor}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="بروزرسانی لیست">
                                <Button.Content>
                                    <materialDesign:PackIcon
                                        Width="30"
                                        Height="30"
                                        VerticalAlignment="Center"
                                        Kind="Refresh" />
                                </Button.Content>
                            </Button>
                        </StackPanel>

                        <Border
                            x:Name="borderNetworkingUsers"
                            Margin="10"
                            BorderBrush="Gray"
                            BorderThickness="2"
                            CornerRadius="5">

                            <StackPanel>
                                <ListBox
                                    x:Name="lstNetworkingUsers"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    ScrollViewer.CanContentScroll="False"
                                    SelectionMode="Single">

                                    <ListBox.Resources>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="Margin" Value="5" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <!--  رنگ پس‌زمینه انتخاب شده  -->
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <!--  رنگ حاشیه انتخاب شده  -->
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Resources>

                                    <ListBox.Template>
                                        <ControlTemplate>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <DockPanel Grid.Row="0" LastChildFill="True">
                                                    <Grid MinHeight="30" DockPanel.Dock="Top">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" HorizontalAlignment="Center">شناسه کاربر</Label>
                                                        <Label Grid.Column="1" HorizontalAlignment="Center">نام کاربر</Label>
                                                        <Label Grid.Column="2" HorizontalAlignment="Center">نقش کاربر</Label>
                                                        <Label Grid.Column="3" HorizontalAlignment="Center">حذف دسترسی</Label>
                                                    </Grid>
                                                    <ItemsPresenter />
                                                </DockPanel>
                                            </Grid>
                                        </ControlTemplate>
                                    </ListBox.Template>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid MinHeight="30">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding UserMobile}"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding UserName}"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding RoleName}"
                                                    TextWrapping="Wrap" />
                                                <Button
                                                    x:Name="btnDeleteAccess"
                                                    Grid.Column="3"
                                                    Width="30"
                                                    Height="30"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Click="btnDeleteAccess_Click"
                                                    Foreground="Red"
                                                    Style="{DynamicResource MaterialDesignIconButton}"
                                                    ToolTip="حذف دسترسی">
                                                    <materialDesign:PackIcon
                                                        Width="20"
                                                        Height="20"
                                                        Kind="AccountRemove" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock
                                    x:Name="lblNoUser"
                                    Margin="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    Text="هیچ کاربری با سند شما مشترک نشده است!"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>

    </Border>
</UserControl>
