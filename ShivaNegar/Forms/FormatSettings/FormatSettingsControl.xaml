<UserControl
    x:Class="ShivaNegar.Forms.FormatSettings.FormatSettingsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="370"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Style for section headers with legend effect -->
            <Style x:Key="SectionHeaderStyle" TargetType="Grid">
                <Setter Property="Height" Value="30"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
                <Setter Property="Margin" Value="0,5,0,15"/>
            </Style>

            <Style x:Key="HeaderLineStyle" TargetType="Border">
                <Setter Property="Height" Value="1"/>
                <Setter Property="Background" Value="{StaticResource PrimaryBackgroundColor}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="15,0"/>
                <Setter Property="Padding" Value="5,0"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryBackgroundColor}"/>
                <Setter Property="Background" Value="{StaticResource LightBackgroundColor}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <Border
            Grid.RowSpan="2"
            Background="{StaticResource PrimaryBackgroundColor}"
            CornerRadius="10" />

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                VerticalAlignment="Top"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Viewbox HorizontalAlignment="Left" StretchDirection="DownOnly">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnCloseApp"
                            Width="30"
                            Height="30"
                            Margin="5"
                            Foreground="White"
                            Style="{DynamicResource MaterialDesignIconButton}"
                            ToolTip="بستن پنجره">
                            <materialDesign:PackIcon Kind="WindowClose" />
                        </Button>
                    </StackPanel>
                </Viewbox>
                

                <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                    <TextBlock
                        x:Name="lblWindowName"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource LightButtonTextColor}"
                        Text="تنظیمات استایل متن"
                        TextAlignment="Center" />
                </Viewbox>
            </Grid>

            <Border
                Grid.Row="1"
                Background="{StaticResource LightBackgroundColor}"
                CornerRadius="10">
                <ScrollViewer Margin="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10 0 10 0">
                        <Grid Style="{StaticResource SectionHeaderStyle}" Margin="0">
                            <Border Style="{StaticResource HeaderLineStyle}" Margin="35,0,0,0"/>
                            <TextBlock Text="انتخاب نوع قالب" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,0"/>
                        </Grid>
                        <ComboBox x:Name="comboHeading"
                             Style="{StaticResource MaterialDesignOutlinedComboBox}"
                             Margin="0,0,0,15"
                             IsTextSearchEnabled="False"
                             StaysOpenOnEdit="True" 
                             materialDesign:HintAssist.Hint="انتخاب نوع قالب">
                        </ComboBox>

                        <Grid Style="{StaticResource SectionHeaderStyle}" Margin="0">
                            <Border Style="{StaticResource HeaderLineStyle}" Margin="35,0,0,0"/>
                            <TextBlock Text="تنظیم فونت" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,0"/>
                        </Grid>
                        <Grid Name="gridFontFamily" Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="233*" />
                                <ColumnDefinition Width="90*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="comboFontFamily"
                                  Grid.Column="0"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,10,0"
                              materialDesign:HintAssist.Hint="نوع فونت فارسی"
                              IsEditable="True"
                              StaysOpenOnEdit="True"
                              GotFocus="comboFontFamily_GotFocus"
                              IsTextSearchEnabled="True"
                              TextBoxBase.TextChanged="ComboFontFamily_TextChanged" Height="53"/>

                            <TextBox x:Name="txtFontSize"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Grid.Column="1"
                             Margin="0,0,0,0"
                             materialDesign:HintAssist.Hint="اندازه فونت"/>
                        </Grid>
                        <Grid Name="gridFontFamilyBi" Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="233*" />
                                <ColumnDefinition Width="90*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="comboFontFamilyBi"
                                 Grid.Column="0"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                             Margin="0,0,10,0"
                             materialDesign:HintAssist.Hint="نوع فونت انگلیسی"
                             IsEditable="True"
                             StaysOpenOnEdit="True"
                             IsTextSearchEnabled="True" FlowDirection="RightToLeft"
                             GotFocus="comboFontFamilyBi_GotFocus"
                             TextBoxBase.TextChanged="ComboFontFamilyBi_TextChanged" Height="53"/>

                            <TextBox x:Name="txtFontSizeBi"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Grid.Column="1"
                            Margin="0,0,0,0"
                            materialDesign:HintAssist.Hint="اندازه فونت"/>
                        </Grid>

                        <ComboBox x:Name="comboFontColor"
                      Margin="0,10,0,15"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="انتخاب رنگ فونت">
                            <ComboBoxItem Content="سیاه" Selector.IsSelected="True" Tag="0,0,0"/>
                            <ComboBoxItem Content="قرمز" Tag="255,0,0"/>
                            <ComboBoxItem Content="سبز" Tag="0,128,0"/>
                            <ComboBoxItem Content="آبی" Tag="0,0,255"/>
                            <ComboBoxItem Content="نارنجی" Tag="255,140,0"/>
                        </ComboBox>

                        <!-- فاصله‌ها -->
                        <Grid Style="{StaticResource SectionHeaderStyle}" Margin="0">
                            <Border Style="{StaticResource HeaderLineStyle}" Margin="35,0,0,0"/>
                            <TextBlock Text="تنظیم فواصل" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,0"/>
                        </Grid>

                        <TextBox x:Name="txtLineSpacing" Margin="0,0,0,10"
                           Grid.Column="0"
                           Style="{StaticResource MaterialDesignOutlinedTextBox}"
                           materialDesign:HintAssist.Hint="فاصله بین سطر ها"
                        />
                        <Grid Name="gridFontSizes" Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtSpaceBefore" Margin="0,0,5,0"
                                     Grid.Column="0"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                materialDesign:HintAssist.Hint="فاصله قبل از پاراگراف"
                             />
                            <TextBox x:Name="txtSpaceAfter" Margin="5,0,0,0"
                                Grid.Column="1"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                materialDesign:HintAssist.Hint="فاصله بعد از پاراگراف"/>
                        </Grid>
                        <Button x:Name="btnApply"
                    Height="45"
                    Content="اعمال تنظیمات"
                    Foreground="{StaticResource LightButtonTextColor}"
                    Click="BtnApply_Click" />
                    </StackPanel>

                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>


</UserControl>