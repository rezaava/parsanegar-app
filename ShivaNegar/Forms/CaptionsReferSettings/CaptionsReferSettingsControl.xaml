<UserControl
    x:Class="ShivaNegar.Forms.CaptionSettings.CaptionSettingsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="370"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="LightBlue"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Style for section headers with legend effect -->
            <Style x:Key="SectionHeaderStyle" TargetType="Grid">
                <Setter Property="Height" Value="30"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
                <Setter Property="Margin" Value="0,5,0,15"/>
            </Style>

            <Style x:Key="HeaderLineStyle" TargetType="Border">
                <Setter Property="Height" Value="1"/>
                <Setter Property="Background" Value="{StaticResource PrimaryBackgroundColor}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,0,0"/>
            </Style>

            <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="15,0"/>
                <Setter Property="Padding" Value="5,0"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryBackgroundColor}"/>
                <Setter Property="Background" Value="{StaticResource LightBackgroundColor}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Name="panelMain">
        <Border
            Grid.RowSpan="2"
            Background="{StaticResource PrimaryBackgroundColor}"
            CornerRadius="10" />

        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                VerticalAlignment="Top"
                Background="{StaticResource PrimaryBackgroundColor}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Viewbox
                        Grid.Column="0"
                        HorizontalAlignment="Left"
                        StretchDirection="DownOnly">
                        <StackPanel Orientation="Horizontal">
                            <Button
                                x:Name="btnCloseApp"
                                Width="30"
                                Height="30"
                                Margin="5"
                                Foreground="White"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                ToolTip="بستن پنجره">
                                <materialDesign:PackIcon Kind="WindowClose" />
                            </Button>

                            
                        </StackPanel>
                    </Viewbox>

                    <Viewbox Grid.Column="1" StretchDirection="DownOnly">
                        <TextBlock
                            x:Name="lblWindowName"
                            VerticalAlignment="Center"
                            FontSize="20"
                            Foreground="{StaticResource LightButtonTextColor}"
                            Text="تنظیمات عنوان و ارجاع"
                            TextAlignment="Center" />
                    </Viewbox>

                    <Grid Grid.Column="2">
                        <ToggleButton
                            Name="toggleButtonAlwaysOnTop"
                            Margin="10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FlowDirection="LeftToRight"
                            Style="{StaticResource MaterialDesignSwitchToggleButton}"
                            ToolTip="پنجره Always on Top تنظیم"
                            UseLayoutRounding="False">

                            <materialDesign:PackIcon Kind="Pin" RenderTransformOrigin=".5,.5">
                                <materialDesign:PackIcon.RenderTransform>
                                    <RotateTransform Angle="45" />
                                </materialDesign:PackIcon.RenderTransform>
                            </materialDesign:PackIcon>

                            <materialDesign:ToggleButtonAssist.OnContent>
                                <materialDesign:PackIcon Foreground="{StaticResource LightBackgroundColor}" Kind="Pin" />
                            </materialDesign:ToggleButtonAssist.OnContent>
                        </ToggleButton>
                    </Grid>
                </Grid>
            </Grid>

            <Border
                Grid.Row="1"
                Background="{StaticResource LightBackgroundColor}"
                CornerRadius="10">
                <ScrollViewer Margin="5" VerticalScrollBarVisibility="Auto">
                    <Viewbox
                        Grid.Column="1"
                        Margin="5,0"
                        VerticalAlignment="Top"
                        StretchDirection="DownOnly">
                        <StackPanel Width="340">
                            <!-- عنوان شکل Section -->
                            <StackPanel Margin="0,5">
                                <!-- Header with legend effect -->
                                <Grid Style="{StaticResource SectionHeaderStyle}">
                                    <Border Style="{StaticResource HeaderLineStyle}" Margin="35,0,0,0"/>
                                    <TextBlock
                                        Text="عنوان شکل"
                                        Style="{StaticResource HeaderTextStyle}" Width="65" Margin="-5,0,0,0"/>
                                </Grid>

                                <StackPanel Margin="15,10">
                                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                        <StackPanel.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="در هنگام درج شکل، کادر محاوره انتخاب عکس ظاهر شود" />
                                            </StackPanel>
                                        </StackPanel.ToolTip>

                                        <ToggleButton
                                            x:Name="tbtnShowDialogCaptionFigure"
                                            Margin="0,0,15,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            FlowDirection="LeftToRight"
                                            UseLayoutRounding="False" />

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,2,0" Text="کادر محاوره انتخاب عکس ظاهر شود" />
                                            <materialDesign:PackIcon
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource PrimaryBackgroundColor}"
                                                Kind="QuestionMarkBox"
                                                UseLayoutRounding="False" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- تنظیم ابعاد شکل‌ها Section -->
                            <StackPanel Margin="0,15">
                                <!-- Header with legend effect -->
                                <Grid Style="{StaticResource SectionHeaderStyle}">
                                    <Border Style="{StaticResource HeaderLineStyle}" Margin="96,0,0,0"/>
                                    <TextBlock
                                        Text="تنظیم ابعاد شکل‌ها"
                                        Style="{StaticResource HeaderTextStyle}" Width="100" RenderTransformOrigin="0.59,0.446" Margin="-9,0,0,0"/>
                                </Grid>

                                <StackPanel Margin="15,10">
                                    <StackPanel
                                        Margin="0,0,0,15"
                                        HorizontalAlignment="Left"
                                        Orientation="Horizontal">
                                        <StackPanel.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="با فعال کردن این گزینه و کلیک بر روی گزینه همترازی، Aspect ratio یا نسبت عکس ها حفظ میشود" />
                                            </StackPanel>
                                        </StackPanel.ToolTip>

                                        <ToggleButton
                                            x:Name="tbtnKeepScaleShape"
                                            Margin="0,0,15,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            FlowDirection="LeftToRight"
                                            UseLayoutRounding="False" />

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,2,0" Text="نسبت شکل حفظ شود" />
                                            <materialDesign:PackIcon
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource PrimaryBackgroundColor}"
                                                Kind="QuestionMarkBox"
                                                UseLayoutRounding="False" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                        <StackPanel.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="با فعال کردن این گزینه و کلیک بر روی گزینه همترازی، یا نسبت عکس ها حفظ میشود" />
                                            </StackPanel>
                                        </StackPanel.ToolTip>

                                        <ToggleButton
                                            x:Name="tbtnNotOverlap"
                                            Margin="0,0,15,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            FlowDirection="LeftToRight"
                                            UseLayoutRounding="False" />

                                        <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                                            <TextBlock Margin="0,0,2,0" Text="شکل‌ها به هم نچسبد" />
                                            <materialDesign:PackIcon
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource PrimaryBackgroundColor}"
                                                Kind="QuestionMarkBox"
                                                UseLayoutRounding="False" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Button
                                        x:Name="btnChangeShapeSizeToContentArea"
                                        Height="45"
                                        Content="همترازی شکل با متن"
                                        Foreground="{StaticResource LightButtonTextColor}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- تنظیم ابعاد جدول‌ها Section -->
                            <StackPanel Margin="0,15">
                                <!-- Header with legend effect -->
                                <Grid Style="{StaticResource SectionHeaderStyle}">
                                    <Border Style="{StaticResource HeaderLineStyle}" HorizontalAlignment="Left" Width="251" Margin="89,0,0,0"/>
                                    <TextBlock
                                        Text="تنظیم ابعاد جدول‌ها"
                                        Style="{StaticResource HeaderTextStyle}" Width="113" Margin="-9,0,0,0"/>
                                </Grid>

                                <StackPanel Margin="15,10">
                                    <Button
                                        x:Name="btnChangeTableSizeToPage"
                                        Height="45"
                                        Margin="0,0,0,15"
                                        Content="همترازی جدول با متن اصلی"
                                        Foreground="{StaticResource LightButtonTextColor}" />
                                    <Button
                                        x:Name="btnChangeTableSizeToContentArea"
                                        Height="45"
                                        Margin="0,0,0,15"
                                        Content="فشرده سازی جدول"
                                        Foreground="{StaticResource LightButtonTextColor}" />
                                    <Button
                                        x:Name="btnRotateTableToRight"
                                        Height="45"
                                        Content="چرخش جدول (سمت راست)"
                                        Foreground="{StaticResource LightButtonTextColor}"
                                        Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Viewbox>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>