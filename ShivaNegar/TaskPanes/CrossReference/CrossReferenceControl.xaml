<UserControl
    x:Class="ShivaNegar.TaskPanes.CrossReference.CrossReferenceControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="300"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="LightBlue"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--  Background="{StaticResource LightBackgroundColor}"  -->
    <Grid Background="{StaticResource LightBackgroundColor}">

        <ScrollViewer
            Margin="5"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">

            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnClose"
                        Margin="0,0,5,0"
                        VerticalAlignment="Stretch"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Foreground="{StaticResource ExitBackgroundButton}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="بستن">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Kind="Close" />
                        </Button.Content>
                    </Button>

                    <Button
                        x:Name="btnRefreshList"
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Stretch"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Foreground="{StaticResource PrimaryBackgroundColor}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="بروزرسانی لیست">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Kind="Refresh" />
                        </Button.Content>
                    </Button>

                </StackPanel>



                <TextBox
                    x:Name="txtSearchCaptions"
                    Grid.Row="1"
                    Margin="0,10"
                    materialDesign:HintAssist.Background="White"
                    materialDesign:HintAssist.FloatingScale="1"
                    materialDesign:HintAssist.Hint="جستجو"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Search"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <ComboBox
                    Name="comboCrossReferenceTo"
                    Grid.Row="2"
                    Margin="0,10"
                    materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                    materialDesign:HintAssist.FloatingScale="1"
                    materialDesign:HintAssist.Hint="ارجاع به"
                    Style="{StaticResource MaterialDesignOutlinedComboBox}" />


                <Grid Grid.Row="3">
                    <TextBlock
                        x:Name="lblNotFound"
                        Margin="0,10"
                        Padding="15"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Text="مرجعی یافت نشد"
                        TextAlignment="Center" />

                    <ListBox
                        x:Name="lstCaptionList"
                        Margin="0,10"
                        ScrollViewer.CanContentScroll="True"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Grid>


                <StackPanel
                    Grid.Row="4"
                    Margin="0,10"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    ToolTip="ارجاع در داخل پرانتز داده خواهد شد">

                    <ToggleButton
                        x:Name="tbtnReferInsideParentheses"
                        Margin="0,0,15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        FlowDirection="LeftToRight"
                        UseLayoutRounding="False" />
                    <TextBlock Text="ارجاع داخل پرانتز باشد" />
                </StackPanel>

                <TextBox
                    x:Name="txtPreview"
                    Grid.Row="5"
                    Grid.Column="1"
                    Margin="0,10"
                    materialDesign:HintAssist.Background="White"
                    materialDesign:HintAssist.FloatingScale="1"
                    materialDesign:HintAssist.Hint="پیش نمایش"
                    IsReadOnly="True"
                    IsReadOnlyCaretVisible="False"
                    TextAlignment="Center" />

                <Button
                    x:Name="btnRefer"
                    Grid.Row="6"
                    Grid.Column="0"
                    Height="45"
                    Margin="0,10"
                    VerticalAlignment="Top"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Content="ارجاع"
                    Foreground="{StaticResource LightButtonTextColor}" />
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
