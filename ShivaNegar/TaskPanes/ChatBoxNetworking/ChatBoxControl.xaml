<UserControl
    x:Class="ShivaNegar.TaskPanes.ChatBoxNetworking.ChatBoxNetworkingControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ShivaNegar.TaskPanes.ChatBoxNetworking"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="300"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="LightBlue"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource LightBackgroundColor}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>


            <TextBlock
                x:Name="lblNoMessage"
                Grid.Row="1"
                Margin="15,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="15"
                FontWeight="Bold"
                Text="پیامی وجود ندارد"
                Visibility="Collapsed" />

            <ListBox
                x:Name="lstMessages"
                Grid.Row="1"
                Margin="10,0"
                HorizontalContentAlignment="Stretch"
                materialDesign:ListBoxItemAssist.ShowSelection="False"
                BorderThickness="0"
                FontFamily="Vazirmatn"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                VirtualizingPanel.ScrollUnit="Pixel"
                VirtualizingStackPanel.IsVirtualizing="True">
                <!--  ItemsSource="{Binding Items}" DataContext="{Binding Items}" MaxWidth="300"  -->
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:MessageItemModel}">
                        <materialDesign:Card
                            Margin="5"
                            HorizontalAlignment="{Binding IsCurrentUser, Converter={StaticResource BooleanToHorizontalAlignmentConverter}}"
                            Background="{Binding IsCurrentUser, Converter={StaticResource BooleanToBackgroundConverter}}"
                            UniformCornerRadius="5">
                            <StackPanel>
                                <TextBlock
                                    Margin="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="{Binding Caption}"
                                    TextWrapping="Wrap"
                                    Visibility="{Binding IsCurrentUser, Converter={StaticResource InvertBooleanToVisibilityConverter}}" />

                                <TextBlock
                                    Margin="15,15"
                                    FontSize="12"
                                    Text="{Binding Message}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>


            <Grid Grid.Row="0" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="btnClose"
                    Grid.Column="0"
                    VerticalAlignment="Stretch"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Foreground="{StaticResource ExitBackgroundButton}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="بستن">
                    <Button.Content>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Kind="Close" />
                    </Button.Content>
                </Button>

                <Button
                    x:Name="btnRefreshList"
                    Grid.Column="1"
                    Margin="5,0"
                    VerticalAlignment="Stretch"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Foreground="{StaticResource PrimaryBackgroundColor}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="بروزرسانی لیست">
                    <Button.Content>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Kind="Refresh" />
                    </Button.Content>
                </Button>
            </Grid>

            <materialDesign:Card Grid.Row="2" materialDesign:ElevationAssist.Elevation="Dp8">

                <materialDesign:Card Margin="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="btnInsert"
                            Grid.Column="0"
                            Margin="0,0,5,0"
                            VerticalAlignment="Stretch"
                            materialDesign:ButtonAssist.CornerRadius="5"
                            Foreground="{StaticResource PrimaryBackgroundColor}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="ارسال پیام">
                            <Button.Content>
                                <materialDesign:PackIcon
                                    Width="30"
                                    Height="30"
                                    VerticalAlignment="Center"
                                    Kind="Send" />
                            </Button.Content>
                        </Button>
                        <TextBox
                            Name="txtMessage"
                            Grid.Row="2"
                            Grid.Column="1"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="متن پیام"
                            AcceptsReturn="True"
                            AcceptsTab="True"
                            BorderThickness="0"
                            FlowDirection="RightToLeft"
                            MaxLines="10"
                            TextWrapping="Wrap" />
                    </Grid>
                </materialDesign:Card>

            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
