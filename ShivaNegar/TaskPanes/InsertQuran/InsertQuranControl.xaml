<UserControl
    x:Class="ShivaNegar.TaskPanes.InsertQuran.InsertQuranControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ShivaNegar.TaskPanes.InsertQuran"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="300"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="LightBlue"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--  Background="{StaticResource LightBackgroundColor}"  -->
    <Grid Background="{StaticResource LightBackgroundColor}">

        <Grid Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                HorizontalAlignment="Left"
                Orientation="Horizontal">
                <Button
                    x:Name="btnClose"
                    VerticalAlignment="Stretch"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Foreground="{StaticResource ExitBackgroundButton}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="بستن">
                    <Button.Content>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Kind="Close" />
                    </Button.Content>
                </Button>
            </StackPanel>

            <ComboBox
                Name="comboSelectSurah"
                Grid.Row="1"
                Margin="0,10"
                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                materialDesign:HintAssist.FloatingScale="1"
                materialDesign:HintAssist.Hint="انتخاب سوره"
                Style="{StaticResource MaterialDesignOutlinedComboBox}" />

            <ListBox
                x:Name="lstQuran"
                Grid.Row="2"
                BorderThickness="0"
                FontFamily="Vazirmatn"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                VirtualizingStackPanel.IsVirtualizing="True">
                <!--  ItemsSource="{Binding Items}" DataContext="{Binding Items}" MaxWidth="300"  -->

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:AyehQuranItem}">
                        <Grid x:Name="testGrid" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                FontSize="12"
                                FontWeight="Bold">
                                <TextBlock Text="آیه " />
                                <TextBlock Text="{Binding AyehNumber}" />
                                <TextBlock Text=": " />
                            </TextBlock>
                            <TextBlock
                                Grid.Column="1"
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="Teal"
                                Text="{Binding AyehText}"
                                TextWrapping="Wrap"
                                ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel
                Grid.Row="3"
                Margin="0,10"
                HorizontalAlignment="Left"
                Orientation="Horizontal"
                ToolTip="نام سوره و شماره آیه نیز درج شود">

                <ToggleButton
                    x:Name="tbtnInsertSurahAyeh"
                    Margin="0,0,15,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FlowDirection="LeftToRight"
                    UseLayoutRounding="False" />
                <TextBlock Text="نام سوره و شماره آیه نیز درج شود" />
            </StackPanel>

            <Button
                x:Name="btnInsertAyeh"
                Grid.Row="4"
                Grid.Column="0"
                Height="45"
                Margin="0,10"
                VerticalAlignment="Top"
                materialDesign:ButtonAssist.CornerRadius="5"
                Content="درج آیه"
                Foreground="{StaticResource LightButtonTextColor}" />
        </Grid>
    </Grid>
</UserControl>
