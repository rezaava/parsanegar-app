<UserControl
    x:Class="ShivaNegar.TaskPanes.InsertDedicate.InsertDedicateControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ShivaNegar.TaskPanes.InsertDedicate"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="300"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="LightBlue"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--  Background="{StaticResource LightBackgroundColor}"  -->
    <Grid Background="{StaticResource LightBackgroundColor}">

        <Grid Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                HorizontalAlignment="Left"
                Orientation="Horizontal">
                <Button
                    x:Name="btnClose"
                    VerticalAlignment="Stretch"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Foreground="{StaticResource ExitBackgroundButton}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="بستن">
                    <Button.Content>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Kind="Close" />
                    </Button.Content>
                </Button>
            </StackPanel>

            <ComboBox
                Name="comboSelectDedicateType"
                Grid.Row="1"
                Margin="0,10"
                materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                materialDesign:HintAssist.FloatingScale="1"
                materialDesign:HintAssist.Hint="انتخاب نوع تقدیم"
                Style="{StaticResource MaterialDesignOutlinedComboBox}" />

            <ListBox
                x:Name="lstDedicate"
                Grid.Row="2"
                BorderThickness="0"
                FontFamily="Vazirmatn"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                VirtualizingStackPanel.IsVirtualizing="True">
                <!--  ItemsSource="{Binding Items}" DataContext="{Binding Items}" MaxWidth="300"  -->

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:DedicateItem}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    FontSize="12"
                                    FontWeight="Bold">
                                    <TextBlock Text="تقدیم شماره " />
                                    <TextBlock Text="{Binding Number}" />
                                    <TextBlock Text=": " />
                                </TextBlock>
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="Teal"
                                    Text="{Binding Dedicate}"
                                    TextWrapping="Wrap"
                                    ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                            </Grid>

                            <Grid
                                Grid.Row="1"
                                Margin="5"
                                Visibility="{Binding BookName, Converter={StaticResource StringToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    FontSize="12"
                                    FontWeight="Bold">
                                    <TextBlock Text="کتاب: " />
                                </TextBlock>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding BookName}"
                                    TextWrapping="Wrap"
                                    ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />

                                <TextBlock
                                    Grid.Column="2"
                                    FontSize="12"
                                    FontWeight="Bold">
                                    <TextBlock Text="نویسنده: " />
                                </TextBlock>
                                <TextBlock
                                    Grid.Column="3"
                                    Text="{Binding Writer}"
                                    TextWrapping="Wrap"
                                    ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                            </Grid>

                        </Grid>

                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button
                x:Name="btnInsertAyeh"
                Grid.Row="4"
                Grid.Column="0"
                Height="45"
                Margin="0,10"
                VerticalAlignment="Top"
                materialDesign:ButtonAssist.CornerRadius="5"
                Content="درج/تغییر متن تقدیم"
                Foreground="{StaticResource LightButtonTextColor}" />
        </Grid>
    </Grid>
</UserControl>
