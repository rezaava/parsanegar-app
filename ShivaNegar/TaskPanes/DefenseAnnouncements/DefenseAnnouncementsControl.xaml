<UserControl
    x:Class="ShivaNegar.TaskPanes.DefenseAnnouncements.DefenseAnnouncementsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ShivaNegar.TaskPanes.DefenseAnnouncements"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="300"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="LightBlue"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--  Background="{StaticResource LightBackgroundColor}"  -->
    <Grid Background="{StaticResource LightBackgroundColor}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Margin="15"
                HorizontalAlignment="Left"
                Orientation="Horizontal">
                <Button
                    x:Name="btnClose"
                    VerticalAlignment="Stretch"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Foreground="{StaticResource ExitBackgroundButton}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="بستن">
                    <Button.Content>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Kind="Close" />
                    </Button.Content>
                </Button>
            </StackPanel>

            <ListBox
                x:Name="lstBox"
                Grid.Row="2"
                Margin="15"
                BorderThickness="0"
                FontFamily="Vazirmatn"
                ItemsSource="{Binding}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                VirtualizingStackPanel.IsVirtualizing="True">
                <!--  ItemsSource="{Binding Items}" DataContext="{Binding Items}" MaxWidth="300"  -->
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:DefenseAnnouncementItem}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Margin="10"
                                HorizontalAlignment="Center"
                                Source="{Binding CoverImage, Converter={StaticResource BitmapToImageSourceConverter}}"
                                Stretch="Uniform">
                                <Image.ToolTip>
                                    <ToolTip Content="{Binding}">
                                        <ToolTip.ContentTemplate>
                                            <DataTemplate>
                                                <Image
                                                    Width="500"
                                                    Height="500"
                                                    Source="{Binding CoverImage, Converter={StaticResource BitmapToImageSourceConverter}}"
                                                    Stretch="Uniform" />
                                            </DataTemplate>
                                        </ToolTip.ContentTemplate>
                                    </ToolTip>
                                </Image.ToolTip>
                            </Image>

                            <Grid
                                Grid.Column="1"
                                Margin="5,20"
                                VerticalAlignment="Bottom">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontSize="12"
                                        FontWeight="Bold">
                                        <TextBlock Text="نام: " />
                                    </TextBlock>
                                    <TextBlock
                                        Grid.Column="1"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="Teal"
                                        Text="{Binding Name}"
                                        TextWrapping="Wrap"
                                        ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                </Grid>
                                <Grid Grid.Row="1" Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontSize="12"
                                        FontWeight="Bold">
                                        <TextBlock Text="برگرفته از: " />
                                    </TextBlock>
                                    <TextBlock
                                        Grid.Column="1"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="Teal"
                                        Text="{Binding SourceFrom}"
                                        TextWrapping="Wrap"
                                        ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                </Grid>
                            </Grid>
                        </Grid>

                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <materialDesign:Card Grid.Row="4" materialDesign:ElevationAssist.Elevation="Dp8">

                <StackPanel Margin="15">
                    <materialDesign:Card Height="45" Margin="0,5">
                        <TextBox
                            Name="txtExaminer"
                            Padding="5"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="استاد داور"
                            AcceptsReturn="True"
                            BorderThickness="0"
                            FlowDirection="RightToLeft"
                            MaxLines="10"
                            TextWrapping="Wrap" />
                    </materialDesign:Card>

                    <materialDesign:Card Height="45" Margin="0,5">
                        <TextBox
                            Name="txtDate"
                            Padding="5"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="تاریخ جلسه"
                            AcceptsReturn="True"
                            BorderThickness="0"
                            FlowDirection="RightToLeft"
                            MaxLines="10"
                            TextWrapping="Wrap" />
                    </materialDesign:Card>

                    <materialDesign:Card Height="45" Margin="0,5">
                        <TextBox
                            Name="txtLocation"
                            Padding="5"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                            materialDesign:HintAssist.FloatingScale="1"
                            materialDesign:HintAssist.Hint="مکان جلسه"
                            AcceptsReturn="True"
                            BorderThickness="0"
                            FlowDirection="RightToLeft"
                            MaxLines="10"
                            TextWrapping="Wrap" />
                    </materialDesign:Card>

                    <Button
                        x:Name="btnCreate"
                        Grid.Row="4"
                        Grid.Column="0"
                        Height="45"
                        Margin="0,10"
                        VerticalAlignment="Top"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Content="ساخت اطلاعیه دفاع"
                        Foreground="{StaticResource LightButtonTextColor}" />
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
