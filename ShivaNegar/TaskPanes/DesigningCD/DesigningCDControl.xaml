<UserControl 
    x:Class="ShivaNegar.TaskPanes.DesigningCD.DesigningCDControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ShivaNegar.TaskPanes.DesigningCD"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="300"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="LightBlue"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--  Background="{StaticResource LightBackgroundColor}"  -->
    <Grid Background="{StaticResource LightBackgroundColor}">

        <ScrollViewer
            Margin="5"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnClose"
                        Margin="0,0,5,0"
                        VerticalAlignment="Stretch"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Foreground="{StaticResource ExitBackgroundButton}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="بستن">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Kind="Close" />
                        </Button.Content>
                    </Button>

                    <Button
                        x:Name="btnRefreshList"
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Stretch"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Foreground="{StaticResource PrimaryBackgroundColor}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="بروزرسانی لیست">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Kind="Refresh" />
                        </Button.Content>
                    </Button>

                </StackPanel>

                <materialDesign:Card
                    Grid.Row="1"
                    Margin="0,10"
                    UniformCornerRadius="5">
                    <materialDesign:Card.Content>

                        <StackPanel>

                            <StackPanel Margin="15,25">

                                <ComboBox
                                    x:Name="comboCDCount"
                                    Grid.Row="0"
                                    Margin="0,15"
                                    materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                    materialDesign:HintAssist.FloatingScale="1"
                                    materialDesign:HintAssist.Hint="تعداد برچسب در خروجی"
                                    SelectedIndex="0"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                    <ComboBoxItem Content="۱ عدد" />
                                    <ComboBoxItem Content="۲ عدد" />
                                </ComboBox>

                                <Grid Margin="0,0,0,10" VerticalAlignment="Center">
                                    <Grid.ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="در هنگام ذخیره و بستن سند، به طور خودکار عملیات همرسانی اتفاق میفتد" />
                                        </StackPanel>
                                    </Grid.ToolTip>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton
                                        x:Name="tbtnEnableThickness"
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        HorizontalAlignment="Left"
                                        FlowDirection="LeftToRight"
                                        UseLayoutRounding="False" />

                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="0,0,5,0"
                                        VerticalAlignment="Center"
                                        Text="فعال سازی خط حاشیه" />

                                    <ComboBox
                                        x:Name="comboThickness"
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="5,0,5,0"
                                        VerticalAlignment="Top"
                                        materialDesign:HintAssist.Background="{StaticResource LightBackgroundColor}"
                                        materialDesign:HintAssist.FloatingScale="1"
                                        materialDesign:HintAssist.Hint="ضخامت"
                                        FlowDirection="LeftToRight"
                                        IsEnabled="False"
                                        SelectedIndex="0">
                                        <ComboBoxItem Content="1 px" />
                                        <ComboBoxItem Content="2 px" />
                                        <ComboBoxItem Content="3 px" />
                                        <ComboBoxItem Content="4 px" />
                                        <ComboBoxItem Content="5 px" />
                                        <ComboBoxItem Content="6 px" />
                                    </ComboBox>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border
                                        x:Name="bdBackgroundColor"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Width="30"
                                        Height="30"
                                        Margin="0,0,10,0"
                                        Background="#FF372F94"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="5" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,0,2,0"
                                        VerticalAlignment="Center"
                                        Text="رنگ پس زمینه" />
                                    <Button
                                        x:Name="btnChangeBackgroundColor"
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="5"
                                        Content="تغییر"
                                        Style="{StaticResource MaterialDesignRaisedDarkButton}" />

                                    <Border
                                        x:Name="bdTextColor"
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Width="30"
                                        Height="30"
                                        Margin="0,0,10,0"
                                        Background="White"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="5" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,0,2,0"
                                        VerticalAlignment="Center"
                                        Text="رنگ متن" />
                                    <Button
                                        x:Name="btnChangeTextColor"
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Margin="5"
                                        Content="تغییر"
                                        Style="{StaticResource MaterialDesignRaisedDarkButton}" />

                                    <Border
                                        x:Name="bdUniversityIconColor"
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Width="30"
                                        Height="30"
                                        Margin="0,0,10,0"
                                        Background="White"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="5" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,0,2,0"
                                        VerticalAlignment="Center"
                                        Text="رنگ نماد دانشگاه" />
                                    <Button
                                        x:Name="btnChangeIconColor"
                                        Grid.Row="2"
                                        Grid.Column="2"
                                        Margin="5"
                                        Content="تغییر"
                                        Style="{StaticResource MaterialDesignRaisedDarkButton}" />

                                    <Border
                                        x:Name="bdBorderColor"
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Width="30"
                                        Height="30"
                                        Margin="0,0,10,0"
                                        Background="Black"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="5" />
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="0,0,2,0"
                                        VerticalAlignment="Center"
                                        Text="رنگ خط حاشیه" />
                                    <Button
                                        x:Name="btnChangeBorderColor"
                                        Grid.Row="3"
                                        Grid.Column="2"
                                        Margin="5"
                                        Content="تغییر"
                                        Style="{StaticResource MaterialDesignRaisedDarkButton}" />


                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card.Content>

                </materialDesign:Card>

                <Button
                    x:Name="btnInsert"
                    Grid.Row="6"
                    Grid.Column="0"
                    Height="45"
                    Margin="0,10"
                    VerticalAlignment="Top"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Content="ساخت طرح لوح فشرده"
                    Foreground="{StaticResource LightButtonTextColor}" />
            </Grid>
        </ScrollViewer>
    </Grid>

</UserControl>
