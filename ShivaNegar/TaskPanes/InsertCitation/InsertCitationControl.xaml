<UserControl
    x:Class="ShivaNegar.TaskPanes.InsertCitation.InsertCitationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ShivaNegar.TaskPanes.InsertCitation"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="300"
    FlowDirection="RightToLeft"
    FontFamily="Vazirmatn"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="LightBlue"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="/ShivaNegar;component/Forms/Styles/MainDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--  Background="{StaticResource LightBackgroundColor}"  -->
    <Grid Background="{StaticResource LightBackgroundColor}">

        <ScrollViewer
            Margin="5"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnClose"
                        Margin="0,0,5,0"
                        VerticalAlignment="Stretch"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Foreground="{StaticResource ExitBackgroundButton}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="بستن">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Kind="Close" />
                        </Button.Content>
                    </Button>

                    <Button
                        x:Name="btnRefreshList"
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Stretch"
                        materialDesign:ButtonAssist.CornerRadius="5"
                        Foreground="{StaticResource PrimaryBackgroundColor}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="بروزرسانی لیست">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="30"
                                Height="30"
                                VerticalAlignment="Center"
                                Kind="Refresh" />
                        </Button.Content>
                    </Button>

                </StackPanel>

                <Viewbox Grid.Row="1" StretchDirection="DownOnly">
                    <materialDesign:Card
                        x:Name="cardNoSourcesFound"
                        Margin="0,10"
                        Padding="5"
                        materialDesign:ElevationAssist.Elevation="Dp2"
                        Background="#FFFE8E08">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Margin="0,5,0,10"
                                FontWeight="Bold"
                                Foreground="{StaticResource LightButtonTextColor}"
                                Text="هیچ منبعی در سند موجود نیست"
                                TextAlignment="Center" />

                            <Grid Grid.Row="1" Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    x:Name="btnImportSources"
                                    Grid.Column="0"
                                    Height="50"
                                    Margin="5,0"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    materialDesign:RippleAssist.Feedback="{StaticResource PrimaryBackgroundColor}"
                                    Background="{StaticResource LightBackgroundColor}"
                                    BorderBrush="{StaticResource LightBackgroundColor}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image
                                            Grid.Column="0"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,5,0"
                                            Source="/ShivaNegar;component/Resources/importSources.png" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Text="وارد کنید  " />
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="btnInsertSources"
                                    Grid.Column="1"
                                    Height="50"
                                    Margin="5,0"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    materialDesign:RippleAssist.Feedback="{StaticResource PrimaryBackgroundColor}"
                                    Background="{StaticResource LightBackgroundColor}"
                                    BorderBrush="{StaticResource LightBackgroundColor}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image
                                            Grid.Column="0"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,5,0"
                                            Source="/ShivaNegar;component/Resources/InsertSources.png" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Text="ایجاد کنید" />
                                    </Grid>
                                </Button>
                            </Grid>

                        </Grid>
                    </materialDesign:Card>
                </Viewbox>

                <TextBox
                    x:Name="txtSearchCitation"
                    Grid.Row="2"
                    Margin="0,10"
                    materialDesign:HintAssist.Background="White"
                    materialDesign:HintAssist.FloatingScale="1"
                    materialDesign:HintAssist.Hint="جستجو"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Search"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <Grid Grid.Row="3">
                    <ListBox
                        x:Name="lstCitation"
                        BorderThickness="0"
                        FontFamily="Vazirmatn"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        VirtualizingStackPanel.IsVirtualizing="True">
                        <!--  ItemsSource="{Binding Items}" DataContext="{Binding Items}" MaxWidth="300"  -->

                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ReferenceItem}">
                                <Grid x:Name="testGrid" Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,6"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Text="عنوان: " />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,6"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="Teal"
                                        Text="{Binding NameOfReference}"
                                        TextWrapping="Wrap"
                                        ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,6"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Text="نویسنده(ها): " />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,6"
                                        FontSize="12"
                                        Text="{Binding Authors}"
                                        TextWrapping="Wrap"
                                        ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Margin="0,6"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Text="نوع منبع: " />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,6"
                                        FontSize="12"
                                        Text="{Binding TypeOfReference}"
                                        TextWrapping="Wrap"
                                        ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock
                        x:Name="txtSourceNotFound"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="منبعی یافت نشد"
                        TextAlignment="Center" />
                </Grid>
                <StackPanel
                    Grid.Row="4"
                    Margin="0,10"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    ToolTip="ارجاع در داخل پرانتز داده خواهد شد">

                    <ToggleButton
                        x:Name="tbtnReferInsideParentheses"
                        Margin="0,0,15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        FlowDirection="LeftToRight"
                        UseLayoutRounding="False" />
                    <TextBlock Text="ارجاع داخل پرانتز باشد" />
                </StackPanel>

                <TextBox
                    x:Name="txtPreview"
                    Grid.Row="5"
                    Grid.Column="1"
                    Margin="0,10"
                    materialDesign:HintAssist.Background="White"
                    materialDesign:HintAssist.FloatingScale="1"
                    materialDesign:HintAssist.Hint="پیش نمایش"
                    IsReadOnly="True"
                    IsReadOnlyCaretVisible="False"
                    TextAlignment="Center" />

                <Button
                    x:Name="btnInsert"
                    Grid.Row="6"
                    Grid.Column="0"
                    Height="45"
                    Margin="0,10"
                    VerticalAlignment="Top"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Content="درج منبع"
                    Foreground="{StaticResource LightButtonTextColor}" />
            </Grid>
        </ScrollViewer>
    </Grid>

</UserControl>
